{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch VsInsertions (https)",
      "type": "process",
      "command": "dotnet",
      "args": [
        "watch",
        "-lp",
        "https",
        "--project",
        "src/VsInsertions"
      ],
      "options": {
        "env": {
          "DOTNET_WATCH_RESTART_ON_RUDE_EDIT": "1",
          "DOTNET_WATCH_SUPPRESS_LAUNCH_BROWSER": "1"
        }
      },
      "isBackground": true,
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}