@page "/flows"
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.DataProtection
@using System.Text.Json.Nodes
@rendermode RenderMode.InteractiveServer
@inject IJSRuntime JSRuntime
@inject IConfiguration Configuration
@inject NavigationManager NavigationManager
@inject IHttpContextAccessor ContextAccessor
@inject MaestroConfigService MaestroConfigService
@inject GitHubFlowService GitHubFlowService
@inject ILogger<Flows> Logger
@inject ILoggerFactory LoggerFactory
@inject FlowsState FlowsState
@inject IDataProtectionProvider DataProtectionProvider

<PageTitle>Flows</PageTitle>

<SectionContent SectionName="page-title">
    <h1 class="page-title">Arcade Flows</h1>
</SectionContent>

@if (actionMessage != null)
{
    <a href="javascript:void(0)" @onclick="ToggleActionAlert" @onclick:preventDefault
       title="@actionMessage"
       style="position: fixed; top: 0.6rem; right: 10rem; z-index: 2; font-size: 1.3rem; cursor: pointer; text-decoration: none;">
        @(actionSuccess ? "\u2705" : "\u26A0\uFE0F")
    </a>

    @* Don't display the alert by default to avoid layout shift when buttons are clicked. *@
    @if (showActionAlert)
    {
        <div id="action-alert" class="alert @(actionSuccess ? "alert-success" : "alert-warning") alert-dismissible mt-3">
            @actionMessage
            <button type="button" class="btn-close" @onclick="DismissActionAlert"></button>
        </div>
    }
}

@* === Auth & Load controls === *@
@{
    var fullyLoggedIn = !string.IsNullOrEmpty(adoAccessToken) && browser
        && (!string.IsNullOrEmpty(gitHubToken) || !string.IsNullOrEmpty(gitHubPatToken));

    RenderFragment adoLogin = @<AdoLogin Organization="dnceng" CookieName="flows_ado_token"
              AccessToken="@adoAccessToken" AccessTokenChanged="HandleAdoTokenChanged"
              LoginLabel="Log In (ADO)" LogoutLabel="Log Out (ADO)" />;

    RenderFragment gitHubStatus = @<text>
        @if (string.IsNullOrEmpty(gitHubToken))
        {
            <span class="badge bg-success">GitHub: @(gitHubUser ?? "PAT")</span>
            <button class="btn btn-outline-dark btn-sm" @onclick="GitHubPatLogOutAsync">Sign out (GitHub PAT)</button>
        }
        else
        {
            <span class="badge bg-success">GitHub: @(gitHubUser ?? "signed in")</span>
            <a href="/signout-github" data-enhance-nav="false" class="btn btn-outline-dark btn-sm">Sign out (GitHub)</a>
        }
    </text>;

    RenderFragment subscriptionButtons = @<text>
        <button class="btn btn-primary" @onclick="LoadSubscriptionsAsync" disabled="@loadingSubscriptions">
            @(loadingSubscriptions ? "Loading..." : "Load Subscriptions")
        </button>
        @if (config != null && !string.IsNullOrEmpty(effectiveGitHubToken) && currentRepo?.StartsWith("dotnet/") == true)
        {
            <button class="btn btn-outline-secondary" @onclick="LoadAllFlowPrsAsync" disabled="@(loadingPrs || loadingOutgoingPrs)">
                @(loadingPrs || loadingOutgoingPrs ? "Loading PRs..." : "Refresh PRs")
            </button>
        }
        @if (rateLimitWaiting)
        {
            <span class="badge bg-warning text-dark" title="Waiting for GitHub rate limit reset">⏳ Rate limited</span>
        }
    </text>;
}

@if (fullyLoggedIn)
{
    @* Compact single-line layout when fully authenticated. *@
    <div class="my-2 d-flex flex-wrap align-items-center gap-2">
        @adoLogin
        @gitHubStatus
        @subscriptionButtons
    </div>
}
else
{
    @* Multi-row layout: show login controls for missing credentials. *@
    <div class="my-2">
        @adoLogin
    </div>

    @if (browser)
    {
        <div class="my-2 d-flex flex-wrap align-items-center gap-2">
            @if (string.IsNullOrEmpty(gitHubToken) && string.IsNullOrEmpty(gitHubPatToken))
            {
                <a href="/signin-github-start?returnUrl=/flows" class="btn btn-dark">
                    Sign in with GitHub
                </a>

                <div class="d-flex align-items-center gap-2">
                    <input type="password" class="form-control form-control-sm" style="width: 260px;"
                           placeholder="GitHub PAT (fallback)" @bind="gitHubPatInput" />
                    <button class="btn btn-outline-dark btn-sm" @onclick="GitHubPatLogInAsync"
                            disabled="@string.IsNullOrEmpty(gitHubPatInput)">Use PAT</button>
                </div>
            }
            else
            {
                @gitHubStatus
            }
        </div>

        @if (string.IsNullOrEmpty(gitHubToken) && string.IsNullOrEmpty(gitHubPatToken))
        {
            <details class="my-2">
                <summary>How do I get a GitHub PAT?</summary>
                <p>
                    Use the <a href="https://cli.github.com/" target="_blank">GitHub CLI</a>:
                </p>
                <ol>
                    <li>
                        <CopyableCode Code="gh auth token" />
                    </li>
                </ol>
                <p>
                    Alternatively, go to
                    <a href="https://github.com/settings/tokens?type=beta" target="_blank">GitHub &gt; Settings &gt; Personal access tokens</a>
                    and create a fine-grained token with <code>Pull requests (Read and write)</code> permission
                    for the repositories you need.
                </p>
            </details>
        }
    }

    @if (!string.IsNullOrEmpty(adoAccessToken))
    {
        <div class="my-2 d-flex flex-wrap align-items-center gap-2">
            @subscriptionButtons
        </div>
    }
}

@if (subscriptionError != null)
{
    <div class="alert alert-danger mt-2">@subscriptionError</div>
}

@* === Subscriptions display === *@
@if (config != null)
{
    <div class="my-3 d-flex align-items-center">
        <label class="me-1">Repository:</label>
        <select class="form-select d-inline-block w-auto me-1" value="@currentRepo" @onchange="OnRepoSelectedAsync">
            @foreach (var entry in SortedRepoEntries())
            {
                <option @key="entry.Name" value="@entry.Name">@entry.Label</option>
            }
        </select>
        <button class="btn btn-sm btn-outline-warning me-3" @onclick="ToggleFavoriteAsync"
                title="@(IsFavorite(currentRepo) ? "Remove from favorites" : "Add to favorites")">
            @(IsFavorite(currentRepo) ? "\u2b50" : "\u2606")
        </button>

        <span class="text-muted">@filteredSubscriptions.Count subscription(s)</span>
    </div>

    @* === Unified flows === *@
    <UnifiedFlowTable Rows="unifiedRows"
                      PrsAvailable="@(!string.IsNullOrEmpty(effectiveGitHubToken) && currentRepo?.StartsWith("dotnet/") == true)"
                      PrError="@prError"
                      OutgoingPrError="@outgoingPrError"
                      ExpandedRows="expandedRows"
                      CollapsedGroups="collapsedGroups"
                      CurrentRepo="@currentRepo"
                      ActionInProgressPr="actionInProgressPr"
                      ActionType="@actionType"
                      OnApprove="ApproveAsync"
                      OnMerge="MergeAsync"
                      OnRetryCi="RetryCiAsync"
                      OnRowExpanded="OnRowExpandedAsync"
                      OnRefreshRow="RefreshRowAsync"
                      OnCollapsedGroupsChanged="SaveCollapsedGroupsAsync" />
}

@* Extra space so expanding/collapsing rows near the bottom doesn't cause scroll jumps. *@
<div style="height: 100vh;"></div>

@code {
    // === State ===
    private bool browser;
    private HashSet<string> favoriteRepos = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> collapsedGroups = new(StringComparer.OrdinalIgnoreCase);
    private List<string> recentRepos = [];
    private const int MaxRecentRepos = 5;
    private const string FavoriteReposCookieName = "flows_favorite_repos";
    private const string RecentReposCookieName = "flows_recent_repos";
    private const string CollapsedGroupsCookieName = "flows_collapsed_groups";
    private string? adoAccessToken;
    private string? gitHubToken;
    private string? gitHubUser;
    private string? gitHubPatToken;
    private string? gitHubPatInput;
    private HttpClient adoClient = new();
    private HttpClient gitHubClient = new();
    private GitHubRateLimitHandler? rateLimitHandler;
    private bool rateLimitWaiting;

    /// <summary>Effective GitHub token: OAuth takes priority, PAT is fallback.</summary>
    private string? effectiveGitHubToken => gitHubToken ?? gitHubPatToken;

    // Subscriptions state (preserved across navigations via FlowsState).
    private MaestroConfig? config { get => FlowsState.Config; set => FlowsState.Config = value; }
    private List<string> repos { get => FlowsState.Repos; set => FlowsState.Repos = value; }
    private string? currentRepo { get => FlowsState.CurrentRepo; set => FlowsState.CurrentRepo = value; }
    private bool loadingSubscriptions;
    private string? subscriptionError;

    // Flow PRs state (preserved across navigations via FlowsState, cached per repo).
    private RepoPrCache currentPrCache => FlowsState.GetOrCreatePrCache(currentRepo ?? "");
    private List<FlowPr>? flowPrs { get => currentPrCache.FlowPrs; set => currentPrCache.FlowPrs = value; }
    private List<FlowPr>? outgoingFlowPrs { get => currentPrCache.OutgoingFlowPrs; set => currentPrCache.OutgoingFlowPrs = value; }
    private List<FlowPr>? closedFlowPrs { get => currentPrCache.ClosedFlowPrs; set => currentPrCache.ClosedFlowPrs = value; }
    private List<FlowPr>? closedOutgoingFlowPrs { get => currentPrCache.ClosedOutgoingFlowPrs; set => currentPrCache.ClosedOutgoingFlowPrs = value; }
    private List<FlowPr>? locPrs { get => currentPrCache.LocPrs; set => currentPrCache.LocPrs = value; }
    private List<FlowPr>? closedLocPrs { get => currentPrCache.ClosedLocPrs; set => currentPrCache.ClosedLocPrs = value; }
    private List<FlowPr>? mergePrs { get => currentPrCache.MergePrs; set => currentPrCache.MergePrs = value; }
    private List<FlowPr>? closedMergePrs { get => currentPrCache.ClosedMergePrs; set => currentPrCache.ClosedMergePrs = value; }
    private bool loadingPrs;
    private bool loadingOutgoingPrs;
    private string? prError;
    private string? outgoingPrError;
    private HashSet<string> expandedRows => currentPrCache.ExpandedRows;

    // Action state.
    private FlowPr? actionInProgressPr;
    private string? actionType;
    private string? actionMessage;
    private bool actionSuccess;
    private bool showActionAlert;
    private bool scrollToAlert;

    private List<ArcadeSubscription> filteredSubscriptions =>
        config?.Subscriptions
            .Where(s => string.Equals(s.SourceRepoShort, currentRepo, StringComparison.OrdinalIgnoreCase)
                     || string.Equals(s.TargetRepoShort, currentRepo, StringComparison.OrdinalIgnoreCase))
            .OrderBy(s => s.Channel)
            .ThenBy(s => s.SourceRepoShort)
            .ToList() ?? [];

    private List<ArcadeSubscription> incomingSubscriptions =>
        filteredSubscriptions
            .Where(s => string.Equals(s.TargetRepoShort, currentRepo, StringComparison.OrdinalIgnoreCase))
            .ToList();

    private List<ArcadeSubscription> outgoingSubscriptions =>
        filteredSubscriptions
            .Where(s => string.Equals(s.SourceRepoShort, currentRepo, StringComparison.OrdinalIgnoreCase))
            .ToList();

    // === Lifecycle ===
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (scrollToAlert)
        {
            scrollToAlert = false;
            await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('action-alert')?.scrollIntoView({ behavior: 'smooth', block: 'center' })");
        }

        if (firstRender)
        {
            // Read GitHub token from OAuth cookie.
            var httpContext = ContextAccessor.HttpContext;
            if (httpContext?.User?.Identity?.IsAuthenticated == true)
            {
                gitHubToken = await httpContext.GetTokenAsync("access_token");
                gitHubUser = httpContext.User.Identity.Name;
            }

            // Read GitHub PAT from cookie as fallback.
            if (string.IsNullOrEmpty(gitHubToken))
            {
                await ReadGitHubPatCookieAsync();
            }

            if (!string.IsNullOrEmpty(effectiveGitHubToken))
            {
                SetupGitHubClient();
                if (string.IsNullOrEmpty(gitHubUser))
                {
                    await FetchGitHubUserAsync();
                }
            }

            await ReadFavoriteReposAsync();
            await ReadRecentReposAsync();
            await ReadCollapsedGroupsAsync();

            browser = true;
            StateHasChanged();
        }
    }

    // === ADO Auth ===
    private async Task HandleAdoTokenChanged(string? token)
    {
        adoAccessToken = token;
        if (token != null)
        {
            subscriptionError = null;
            if (FlowsState.AdoAccessToken != token)
            {
                FlowsState.AdoAccessToken = token;
                config = null;
            }
            SetupAdoClient();
            if (config == null)
            {
                await LoadSubscriptionsAsync();
            }
        }
        else
        {
            FlowsState.AdoAccessToken = null;
            config = null;
            ClearFlowPrState();
        }
    }

    private void SetupAdoClient()
    {
        adoClient = new HttpClient(new LoggingHttpHandler(LoggerFactory.CreateLogger("HTTP.ADO")));
        adoClient.DefaultRequestHeaders.Add("Authorization", $"Bearer {adoAccessToken}");
    }

    private void SetupGitHubClient()
    {
        rateLimitHandler = new GitHubRateLimitHandler(LoggerFactory.CreateLogger("HTTP.GitHub.RateLimit"))
        {
            InnerHandler = new LoggingHttpHandler(LoggerFactory.CreateLogger("HTTP.GitHub")),
        };
        rateLimitHandler.WaitingChanged = waiting =>
        {
            rateLimitWaiting = waiting;
            InvokeAsync(StateHasChanged);
        };
        gitHubClient = new HttpClient(rateLimitHandler);
        gitHubClient.DefaultRequestHeaders.Add("Authorization", $"Bearer {effectiveGitHubToken}");
        gitHubClient.DefaultRequestHeaders.Add("User-Agent", "VsInsertions");
        gitHubClient.DefaultRequestHeaders.Add("Accept", "application/vnd.github+json");
    }

    private async Task FetchGitHubUserAsync()
    {
        try
        {
            var json = await gitHubClient.GetStringAsync("https://api.github.com/user");
            var node = System.Text.Json.Nodes.JsonNode.Parse(json);
            gitHubUser = node?["login"]?.ToString();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to fetch GitHub user");
        }
    }

    // === GitHub PAT ===
    private const string GitHubPatCookieName = "flows_github_pat";

    private async Task ReadGitHubPatCookieAsync()
    {
        var encrypted = await JSRuntime.InvokeAsync<string>("getCookie", GitHubPatCookieName);
        try
        {
            var token = string.IsNullOrEmpty(encrypted) ? null :
                DataProtectionProvider.CreateProtector(GitHubPatCookieName).Unprotect(encrypted);
            if (!string.IsNullOrEmpty(token))
            {
                gitHubPatToken = token;
                FlowsState.GitHubPatToken = token;
            }
        }
        catch
        {
            // Cookie corrupt or key rotated — ignore.
        }
    }

    private async Task GitHubPatLogInAsync()
    {
        if (string.IsNullOrEmpty(gitHubPatInput))
            return;

        var token = gitHubPatInput;
        var encrypted = DataProtectionProvider.CreateProtector(GitHubPatCookieName).Protect(token);
        await JSRuntime.InvokeVoidAsync("setCookie", GitHubPatCookieName, encrypted);
        gitHubPatInput = null;
        gitHubPatToken = token;
        FlowsState.GitHubPatToken = token;
        SetupGitHubClient();
        await FetchGitHubUserAsync();

        await AutoLoadFlowPrsAsync();
    }

    private async Task GitHubPatLogOutAsync()
    {
        await JSRuntime.InvokeVoidAsync("setCookie", GitHubPatCookieName, "");
        gitHubPatToken = null;
        FlowsState.GitHubPatToken = null;
        ClearFlowPrState();
    }

    // === Load Subscriptions ===
    private async Task LoadSubscriptionsAsync()
    {
        loadingSubscriptions = true;
        subscriptionError = null;
        StateHasChanged();

        try
        {
            config = await MaestroConfigService.GetConfigAsync(adoClient);
            repos = MaestroConfigService.GetUniqueRepos(config.Subscriptions);
            if (repos.Count > 0 && (currentRepo == null || !repos.Contains(currentRepo)))
            {
                // Default to dotnet/roslyn if available, otherwise first repo.
                currentRepo = repos.FirstOrDefault(r => r.Equals("dotnet/roslyn", StringComparison.OrdinalIgnoreCase))
                    ?? repos[0];
            }
            ClearFlowPrState();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load subscriptions");
            subscriptionError = $"Failed to load subscriptions: {ex.Message}";
        }
        finally
        {
            loadingSubscriptions = false;
            StateHasChanged();
        }

        await AutoLoadFlowPrsAsync();
    }

    private void ClearFlowPrState()
    {
        FlowsState.RepoPrCaches.Clear();
    }

    private async Task AutoLoadFlowPrsAsync()
    {
        if (!string.IsNullOrEmpty(effectiveGitHubToken) && currentRepo?.StartsWith("dotnet/") == true)
        {
            // Skip loading if PRs are already cached for this repo.
            if (flowPrs != null)
                return;

            await LoadAllFlowPrsAsync();
        }
    }

    // === Load Flow PRs ===
    private async Task LoadAllFlowPrsAsync()
    {
        if (string.IsNullOrEmpty(currentRepo) || config is null)
            return;

        var parts = currentRepo.Split('/');
        if (parts.Length != 2)
            return;

        var targetRepos = outgoingSubscriptions
            .Select(s => s.TargetRepoShort)
            .Where(r => !string.Equals(r, currentRepo, StringComparison.OrdinalIgnoreCase))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        loadingPrs = true;
        loadingOutgoingPrs = true;
        prError = null;
        outgoingPrError = null;
        expandedRows.Clear();
        StateHasChanged();

        try
        {
            var results = await GitHubFlowService.SearchAllPrsAsync(
                gitHubClient, parts[0], parts[1], targetRepos);

            flowPrs = results.OpenFlowPrs
                .OrderBy(p => p.Repo, StringComparer.OrdinalIgnoreCase)
                .ThenByDescending(p => p.Number)
                .ToList();
            closedFlowPrs = results.ClosedFlowPrs
                .OrderBy(p => p.Repo, StringComparer.OrdinalIgnoreCase)
                .ThenByDescending(p => p.Number)
                .ToList();
            locPrs = results.OpenLocPrs
                .OrderByDescending(p => p.Number)
                .ToList();
            closedLocPrs = results.ClosedLocPrs
                .OrderByDescending(p => p.Number)
                .ToList();
            mergePrs = results.OpenMergePrs
                .OrderByDescending(p => p.Number)
                .ToList();
            closedMergePrs = results.ClosedMergePrs
                .OrderByDescending(p => p.Number)
                .ToList();
            outgoingFlowPrs = results.OpenOutgoingFlowPrs
                .OrderBy(p => p.Repo, StringComparer.OrdinalIgnoreCase)
                .ThenByDescending(p => p.Number)
                .ToList();
            closedOutgoingFlowPrs = results.ClosedOutgoingFlowPrs
                .OrderBy(p => p.Repo, StringComparer.OrdinalIgnoreCase)
                .ThenByDescending(p => p.Number)
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load flow PRs");
            prError = $"Failed to load flow PRs: {ex.Message}";
        }
        finally
        {
            loadingPrs = false;
            loadingOutgoingPrs = false;
            StateHasChanged();
        }

        await LoadDisplayedPrDetailsAsync();
    }

    /// <summary>
    /// Loads details for all currently displayed PRs in one batched GraphQL request.
    /// Re-checks after loading in case grouping changes reveal new PRs.
    /// </summary>
    private async Task LoadDisplayedPrDetailsAsync()
    {
        while (true)
        {
            var prsToLoad = unifiedRows.SelectMany(r => r.Prs)
                .Where(p => !p.DetailsLoaded)
                .Distinct()
                .ToList();
            if (prsToLoad.Count == 0) break;

            await GitHubFlowService.LoadPrDetailsBatchAsync(gitHubClient, prsToLoad);
            StateHasChanged();
        }
    }

    private async Task LoadPrDetailsAsync(FlowPr pr)
    {
        pr.DetailsLoaded = false;
        await GitHubFlowService.LoadPrDetailsBatchAsync(gitHubClient, [pr]);
        StateHasChanged();
    }

    // === Actions ===
    private async Task ApproveAsync(FlowPr pr)
    {
        var parts = pr.Repo.Split('/');
        if (parts.Length != 2)
            return;

        actionInProgressPr = pr;
        actionType = "approve";
        actionMessage = null;
        StateHasChanged();

        try
        {
            var (success, message) = await GitHubFlowService.ApproveAsync(gitHubClient, parts[0], parts[1], pr);
            actionSuccess = success;
            actionMessage = message;

            if (success)
            {
                // Reload just this PR's details (reviews, checks, comments) for accuracy.
                await LoadPrDetailsAsync(pr);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to approve PR");
            actionSuccess = false;
            actionMessage = $"Error: {ex.Message}";
        }
        finally
        {
            actionInProgressPr = null;
            actionType = null;
            StateHasChanged();
        }
    }

    private async Task MergeAsync(FlowPr pr)
    {
        var parts = pr.Repo.Split('/');
        if (parts.Length != 2)
            return;

        actionInProgressPr = pr;
        actionType = "merge";
        actionMessage = null;
        StateHasChanged();

        try
        {
            var (success, message) = await GitHubFlowService.MergeAsync(gitHubClient, parts[0], parts[1], pr);
            actionSuccess = success;
            actionMessage = message;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to merge PR");
            actionSuccess = false;
            actionMessage = $"Error: {ex.Message}";
        }
        finally
        {
            actionInProgressPr = null;
            actionType = null;
            StateHasChanged();
        }
    }

    private async Task RetryCiAsync(FlowPr pr)
    {
        var parts = pr.Repo.Split('/');
        if (parts.Length != 2)
            return;

        actionInProgressPr = pr;
        actionType = "retry";
        actionMessage = null;
        StateHasChanged();

        try
        {
            var (success, message) = await GitHubFlowService.RetryCiAsync(gitHubClient, parts[0], parts[1], pr, adoClient);
            actionSuccess = success;
            actionMessage = message;

            // Refresh details after retry.
            if (success)
            {
                await LoadPrDetailsAsync(pr);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to retry CI");
            actionSuccess = false;
            actionMessage = $"Error: {ex.Message}";
        }
        finally
        {
            actionInProgressPr = null;
            actionType = null;
            StateHasChanged();
        }
    }

    // === Lazy Annotation Loading ===

    private async Task OnRowExpandedAsync(UnifiedFlowRow row)
    {
        await LoadAnnotationsAsync(row);
    }

    private async Task RefreshRowAsync(UnifiedFlowRow row)
    {
        foreach (var pr in row.Prs)
        {
            pr.DetailsLoaded = false;
            pr.AnnotationsLoaded = false;
        }
        StateHasChanged();
        await GitHubFlowService.LoadPrDetailsBatchAsync(gitHubClient, row.Prs);
        StateHasChanged();
        await LoadAnnotationsAsync(row);
    }

    private async Task LoadAnnotationsAsync(UnifiedFlowRow row)
    {
        var prsToLoad = row.Prs
            .Where(p => p.DetailsLoaded && !p.AnnotationsLoaded
                && p.CheckRuns?.Any(c => c.Conclusion is "failure" or "cancelled" or "timed_out") == true)
            .ToList();

        if (prsToLoad.Count == 0)
            return;

        await Task.WhenAll(prsToLoad.Select(pr =>
            GitHubFlowService.LoadCheckAnnotationsAsync(gitHubClient, pr)));
        StateHasChanged();
    }

    // === UI Helpers ===

    private void ToggleActionAlert()
    {
        showActionAlert = !showActionAlert;
        scrollToAlert = showActionAlert;
    }

    private void DismissActionAlert()
    {
        actionMessage = null;
        showActionAlert = false;
    }

    // === Favorite / Recent repos ===

    private async Task ReadFavoriteReposAsync()
    {
        var value = await JSRuntime.InvokeAsync<string>("getCookie", FavoriteReposCookieName);
        if (!string.IsNullOrEmpty(value))
        {
            favoriteRepos = new HashSet<string>(
                value.Split(',', StringSplitOptions.RemoveEmptyEntries),
                StringComparer.OrdinalIgnoreCase);
        }
    }

    private async Task SaveFavoriteReposAsync()
    {
        var value = string.Join(",", favoriteRepos);
        await JSRuntime.InvokeVoidAsync("setCookie", FavoriteReposCookieName, value);
    }

    private async Task ReadRecentReposAsync()
    {
        var value = await JSRuntime.InvokeAsync<string>("getCookie", RecentReposCookieName);
        if (!string.IsNullOrEmpty(value))
        {
            recentRepos = value.Split(',', StringSplitOptions.RemoveEmptyEntries).ToList();
        }
    }

    private async Task SaveRecentReposAsync()
    {
        var value = string.Join(",", recentRepos);
        await JSRuntime.InvokeVoidAsync("setCookie", RecentReposCookieName, value);
    }

    private async Task ReadCollapsedGroupsAsync()
    {
        var value = await JSRuntime.InvokeAsync<string>("getCookie", CollapsedGroupsCookieName);
        if (!string.IsNullOrEmpty(value))
        {
            collapsedGroups = new HashSet<string>(
                value.Split(',', StringSplitOptions.RemoveEmptyEntries),
                StringComparer.OrdinalIgnoreCase);
        }
    }

    private async Task SaveCollapsedGroupsAsync()
    {
        var value = string.Join(",", collapsedGroups);
        await JSRuntime.InvokeVoidAsync("setCookie", CollapsedGroupsCookieName, value);
    }

    private bool IsFavorite(string? repo) =>
        repo != null && favoriteRepos.Contains(repo);

    private async Task ToggleFavoriteAsync()
    {
        if (currentRepo is null) return;

        if (favoriteRepos.Contains(currentRepo))
            favoriteRepos.Remove(currentRepo);
        else
            favoriteRepos.Add(currentRepo);

        await SaveFavoriteReposAsync();
    }

    private async Task OnRepoSelectedAsync(ChangeEventArgs e)
    {
        var newRepo = e.Value?.ToString();
        if (string.IsNullOrEmpty(newRepo)) return;

        currentRepo = newRepo;
        prError = null;
        outgoingPrError = null;

        // Update recent repos list (most recent first, no duplicates, capped).
        recentRepos.RemoveAll(r => string.Equals(r, newRepo, StringComparison.OrdinalIgnoreCase));
        recentRepos.Insert(0, newRepo);
        if (recentRepos.Count > MaxRecentRepos)
            recentRepos.RemoveRange(MaxRecentRepos, recentRepos.Count - MaxRecentRepos);

        await SaveRecentReposAsync();

        await AutoLoadFlowPrsAsync();
    }

    private List<(string Name, string Label)> SortedRepoEntries()
    {
        var entries = new List<(string Name, string Label, int Order)>();

        foreach (var repo in repos)
        {
            if (favoriteRepos.Contains(repo))
                entries.Add((repo, $"\u2b50 {repo}", 0));
            else if (recentRepos.Contains(repo))
                entries.Add((repo, $"\ud83d\udd52 {repo}", 1));
            else
                entries.Add((repo, repo, 2));
        }

        return entries
            .OrderBy(e => e.Order)
            .ThenBy(e => e.Name, StringComparer.OrdinalIgnoreCase)
            .Select(e => (e.Name, e.Label))
            .ToList();
    }

    /// <summary>
    /// Resolves the source branch for a subscription by looking up the default channel
    /// that matches the subscription's source repository and channel.
    /// </summary>
    private string? ResolveSourceBranch(ArcadeSubscription sub)
    {
        if (config is null || string.IsNullOrEmpty(sub.SourceRepository) || string.IsNullOrEmpty(sub.Channel))
            return null;

        var dc = FindDefaultChannel(sub.SourceRepoShort, sub.Channel)
              ?? FindDefaultChannel(sub.SourceRepoShort, sub.Channel + " - Validation");

        return dc?.Branch;
    }

    private DefaultChannel? FindDefaultChannel(string sourceRepoShort, string channel)
    {
        return config?.DefaultChannels.FirstOrDefault(dc =>
            dc.Enabled
            && string.Equals(dc.Channel, channel, StringComparison.OrdinalIgnoreCase)
            && string.Equals(
                MaestroConfigService.NormalizeRepoName(dc.Repository ?? ""),
                sourceRepoShort,
                StringComparison.OrdinalIgnoreCase));
    }

    // === Unified flow rows ===

    private List<UnifiedFlowRow> unifiedRows => BuildUnifiedFlowRows();

    private List<UnifiedFlowRow> BuildUnifiedFlowRows()
    {
        if (config is null)
            return [];

        var rows = new List<UnifiedFlowRow>();


        // Incoming subscriptions (other → selected repo).
        foreach (var sub in incomingSubscriptions)
        {
            var matched = (flowPrs ?? [])
                .Where(pr => pr.Title.Contains(sub.SourceRepoShort, StringComparison.OrdinalIgnoreCase)
                    && MatchesTargetBranch(pr, sub.TargetBranch))
                .OrderByDescending(pr => pr.Number)
                .ToList();
            // If no open PRs, fall back to the most recent closed PR.
            if (matched.Count == 0)
            {
                var closedMatch = (closedFlowPrs ?? [])
                    .Where(pr => pr.Title.Contains(sub.SourceRepoShort, StringComparison.OrdinalIgnoreCase)
                        && MatchesTargetBranch(pr, sub.TargetBranch))
                    .OrderByDescending(pr => pr.Number)
                    .Take(1)
                    .ToList();
                matched = closedMatch;
            }

            rows.Add(new UnifiedFlowRow
            {
                OtherRepo = sub.SourceRepoShort,
                IsIncoming = true,
                Subscription = sub,
                SourceBranch = ResolveSourceBranch(sub),
                Prs = matched,
            });
        }

        // Outgoing subscriptions (selected repo → other).
        // Skip circular subscriptions (source == target) as they are already handled above.
        foreach (var sub in outgoingSubscriptions.Where(s =>
            !string.Equals(s.SourceRepoShort, s.TargetRepoShort, StringComparison.OrdinalIgnoreCase)))
        {
            var matched = (outgoingFlowPrs ?? [])
                .Where(pr => string.Equals(pr.Repo, sub.TargetRepoShort, StringComparison.OrdinalIgnoreCase)
                    && MatchesTargetBranch(pr, sub.TargetBranch))
                .OrderByDescending(pr => pr.Number)
                .ToList();
            // If no open PRs, fall back to the most recent closed PR.
            if (matched.Count == 0)
            {
                var closedMatch = (closedOutgoingFlowPrs ?? [])
                    .Where(pr => string.Equals(pr.Repo, sub.TargetRepoShort, StringComparison.OrdinalIgnoreCase)
                        && MatchesTargetBranch(pr, sub.TargetBranch))
                    .OrderByDescending(pr => pr.Number)
                    .Take(1)
                    .ToList();
                matched = closedMatch;
            }

            rows.Add(new UnifiedFlowRow
            {
                OtherRepo = sub.TargetRepoShort,
                IsIncoming = false,
                Subscription = sub,
                SourceBranch = ResolveSourceBranch(sub),
                Prs = matched,
            });
        }

        // Inter-branch merge PRs (github-actions[bot]) — group by source→target branch pair.
        {
            var allMerge = (mergePrs ?? []).Concat(closedMergePrs ?? []).ToList();
            var branchGroups = allMerge
                .GroupBy(pr =>
                {
                    var (src, tgt) = ExtractMergeBranches(pr.Title);
                    return $"{src ?? "?"}=>{tgt ?? pr.TargetBranch ?? "?"}";
                }, StringComparer.OrdinalIgnoreCase)
                .ToList();

            foreach (var group in branchGroups)
            {
                var open = group.Where(p => p.State == "open").OrderByDescending(p => p.Number).ToList();
                var closed = group.Where(p => p.State != "open").OrderByDescending(p => p.Number).ToList();
                var prs = open.Count > 0 ? open : closed.Take(1).ToList();
                var sample = prs[0];
                var (srcBranch, _) = ExtractMergeBranches(sample.Title);
                rows.Add(new UnifiedFlowRow
                {
                    OtherRepo = currentRepo ?? "unknown",
                    IsIncoming = true,
                    IsSameRepo = true,
                    SourceBranch = srcBranch,
                    Prs = prs,
                });
            }
        }

        // Loc PRs — group by target branch, one row per branch.
        {
            var allLoc = (locPrs ?? []).Concat(closedLocPrs ?? []).ToList();
            var branchGroups = allLoc
                .GroupBy(pr => pr.TargetBranch ?? "unknown", StringComparer.OrdinalIgnoreCase)
                .ToList();

            foreach (var group in branchGroups)
            {
                var open = group.Where(p => p.State == "open").OrderByDescending(p => p.Number).ToList();
                var closed = group.Where(p => p.State != "open").OrderByDescending(p => p.Number).ToList();
                var prs = open.Count > 0 ? open : closed.Take(1).ToList();
                rows.Add(new UnifiedFlowRow
                {
                    OtherRepo = "Localization (OneLocBuild)",
                    IsIncoming = true,
                    Prs = prs,
                });
            }
        }

        return rows
            .OrderBy(r => r.OtherRepo, StringComparer.OrdinalIgnoreCase)
            .ThenBy(r => r.IsIncoming ? 0 : 1)
            .ThenBy(r => r.Subscription?.Channel)
            .ThenBy(r => r.Subscription?.TargetBranch)
            .ToList();
    }

    /// <summary>
    /// Checks if a PR matches the expected target branch.
    /// Uses <see cref="FlowPr.TargetBranch"/> if loaded, otherwise extracts
    /// the branch from the title (e.g., "[main] Update dependencies...").
    /// </summary>
    private static bool MatchesTargetBranch(FlowPr pr, string? expectedBranch)
    {
        if (expectedBranch is null)
            return true;

        var prBranch = pr.TargetBranch ?? ExtractTargetBranchFromTitle(pr.Title);
        if (prBranch is null)
            return true;

        return string.Equals(prBranch, expectedBranch, StringComparison.OrdinalIgnoreCase);
    }

    /// <summary>
    /// Extracts the target branch from a maestro PR title like
    /// "[main] Update dependencies from dotnet/runtime" → "main".
    /// </summary>
    private static string? ExtractTargetBranchFromTitle(string title)
    {
        if (title.StartsWith('['))
        {
            var end = title.IndexOf(']');
            if (end > 1)
                return title[1..end];
        }
        return null;
    }

    /// <summary>
    /// Extracts source and target branches from an inter-branch merge PR title like
    /// "[automated] Merge branch 'release/10.0.3xx' => 'main'" → ("release/10.0.3xx", "main").
    /// </summary>
    private static (string? Source, string? Target) ExtractMergeBranches(string title)
    {
        // Pattern: ... Merge branch 'source' => 'target'
        const string prefix = "Merge branch '";
        var start = title.IndexOf(prefix, StringComparison.OrdinalIgnoreCase);
        if (start < 0)
            return (null, null);
        start += prefix.Length;
        var end1 = title.IndexOf('\'', start);
        if (end1 < 0)
            return (null, null);
        var source = title[start..end1];

        const string arrow = "=> '";
        var arrowIdx = title.IndexOf(arrow, end1, StringComparison.Ordinal);
        if (arrowIdx < 0)
            return (source, null);
        var start2 = arrowIdx + arrow.Length;
        var end2 = title.IndexOf('\'', start2);
        var target = end2 >= 0 ? title[start2..end2] : title[start2..];

        return (source, target);
    }

}
