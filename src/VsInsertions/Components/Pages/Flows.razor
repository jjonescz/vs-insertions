@page "/flows"
@using Microsoft.AspNetCore.Authentication
@using System.Text.Json.Nodes
@rendermode RenderMode.InteractiveServer
@inject IJSRuntime JSRuntime
@inject IConfiguration Configuration
@inject NavigationManager NavigationManager
@inject IHttpContextAccessor ContextAccessor
@inject MaestroConfigService MaestroConfigService
@inject GitHubFlowService GitHubFlowService
@inject ILogger<Flows> Logger
@inject ILoggerFactory LoggerFactory
@inject FlowsState FlowsState

<PageTitle>Flows</PageTitle>

<SectionContent SectionName="page-title">
    <h1 class="page-title">Arcade Flows</h1>
</SectionContent>

@* === Azure DevOps PAT section (for maestro-configuration) === *@
<div class="my-2">
    <AdoLogin Organization="dnceng" CookieName="flows_ado_token"
              AccessToken="@adoAccessToken" AccessTokenChanged="HandleAdoTokenChanged"
              LoginLabel="Log In (ADO)" LogoutLabel="Log Out (ADO)" />
</div>

@* === GitHub OAuth section === *@
@if (browser)
{
    <div class="my-2">
        @if (string.IsNullOrEmpty(gitHubToken))
        {
            <a href="/signin-github-start?returnUrl=/flows" class="btn btn-dark">
                Sign in with GitHub
            </a>
            <small class="text-muted ms-2">Required for viewing and managing flow PRs</small>
        }
        else
        {
            <span class="badge bg-success me-2">GitHub: @(gitHubUser ?? "signed in")</span>
            <a href="/signout-github" data-enhance-nav="false" class="btn btn-outline-dark btn-sm">Sign out (GitHub)</a>
        }
    </div>
}

@* === Load button === *@
@if (!string.IsNullOrEmpty(adoAccessToken))
{
    <div class="my-2">
        <button class="btn btn-primary me-2" @onclick="LoadSubscriptionsAsync" disabled="@loadingSubscriptions">
            @(loadingSubscriptions ? "Loading..." : "Load Subscriptions")
        </button>

        @if (subscriptionError != null)
        {
            <div class="alert alert-danger mt-2">@subscriptionError</div>
        }
    </div>
}

@* === Subscriptions display === *@
@if (config != null)
{
    <div class="my-3">
        <label class="me-1">Repository:</label>
        <select class="form-select d-inline-block w-auto me-3" @bind="currentRepo">
            @foreach (var repo in repos)
            {
                <option value="@repo">@repo</option>
            }
        </select>

        <span class="text-muted">@filteredSubscriptions.Count subscription(s)</span>
    </div>

    @* === Flow PRs section === *@
    @if (!string.IsNullOrEmpty(gitHubToken) && !string.IsNullOrEmpty(currentRepo) && currentRepo.StartsWith("dotnet/"))
    {
        <div class="my-3">
            <h4>
                Flow PRs
                <button class="btn btn-outline-secondary btn-sm ms-2" @onclick="LoadFlowPrsAsync" disabled="@loadingPrs">
                    @(loadingPrs ? "Loading..." : "Load / Refresh")
                </button>
            </h4>

            @if (prError != null)
            {
                <div class="alert alert-danger mt-2">@prError</div>
            }

            @if (flowPrs != null)
            {
                @if (flowPrs.Count == 0)
                {
                    <p class="text-muted">No open flow PRs found.</p>
                }
                else
                {
                    <table class="table table-hover w-auto align-middle">
                        <thead>
                            <tr>
                                <th>PR #</th>
                                <th title="State">S</th>
                                <th>Title</th>
                                <th>Target</th>
                                <th>CI</th>
                                <th>Reviews</th>
                                <th title="Non-bot comments">💬</th>
                                <th>Actions</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pr in flowPrs)
                            {
                                <tr>
                                    <td><a href="@pr.Url" target="_blank">#@pr.Number</a></td>
                                    <td title="@pr.State">@PrStateToEmoji(pr)</td>
                                    <td title="@pr.Title" style="max-width: 400px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        @TruncateTitle(pr.Title)
                                    </td>
                                    <td><code>@(pr.TargetBranch ?? "—")</code></td>

                                    @* CI status *@
                                    <td title="Click to expand CI details">
                                        @if (!pr.DetailsLoaded)
                                        {
                                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => LoadPrDetailsAsync(pr)">
                                                Load
                                            </button>
                                        }
                                        else
                                        {
                                            <span>@pr.CiSummary</span>
                                        }
                                    </td>

                                    @* Reviews *@
                                    <td>
                                        @if (pr.Reviews != null)
                                        {
                                            @foreach (var review in pr.Reviews.GroupBy(r => r.Author).Select(g => g.Last()))
                                            {
                                                @if (review.AvatarUrl != null)
                                                {
                                                    <img src="@review.AvatarUrl" title="@review.Author: @review.State"
                                                         style="width: 1.2em; height: 1.2em; border-radius: 50%; border: 0.15em solid @ReviewStateToColor(review.State); margin-right: 2px;" />
                                                }
                                                else
                                                {
                                                    <span title="@review.Author: @review.State" style="color: @ReviewStateToColor(review.State);">
                                                        @review.Author[..1]
                                                    </span>
                                                }
                                            }
                                        }
                                    </td>

                                    @* Comments *@
                                    <td>@(pr.Comments?.Count ?? 0)</td>

                                    @* Action buttons *@
                                    <td>
                                        @if (pr.State == "open" && !pr.Merged)
                                        {
                                            <button class="btn btn-success btn-sm me-1"
                                                    @onclick="() => ApproveAndMergeAsync(pr)"
                                                    disabled="@(pr == actionInProgressPr)"
                                                    title="Approve, squash-merge, and delete branch">
                                                @if (pr == actionInProgressPr && actionType == "merge")
                                                {
                                                    @:Merging...
                                                }
                                                else
                                                {
                                                    @:Approve & Merge
                                                }
                                            </button>

                                            @if (pr.DetailsLoaded && pr.CheckRuns?.Any(c => c.Conclusion is "failure" or "cancelled" or "timed_out") == true)
                                            {
                                                <button class="btn btn-warning btn-sm"
                                                        @onclick="() => RetryCiAsync(pr)"
                                                        disabled="@(pr == actionInProgressPr)"
                                                        title="Re-run failed CI checks">
                                                    @if (pr == actionInProgressPr && actionType == "retry")
                                                    {
                                                        @:Retrying...
                                                    }
                                                    else
                                                    {
                                                        @:Retry CI
                                                    }
                                                </button>
                                            }
                                        }
                                    </td>

                                    @* Expand details *@
                                    <td>
                                        @if (pr.DetailsLoaded)
                                        {
                                            <button class="btn btn-outline-secondary btn-sm"
                                                    @onclick="() => ToggleDetails(pr)"
                                                    title="Show/hide details">
                                                @(expandedPrs.Contains(pr.Number) ? "▲" : "▼")
                                            </button>
                                        }
                                    </td>
                                </tr>

                                @* Expanded details row *@
                                @if (expandedPrs.Contains(pr.Number))
                                {
                                    <tr>
                                        <td colspan="9">
                                            <div class="p-2" style="background-color: #f8f9fa;">
                                                @if (pr.CheckRuns is { Count: > 0 })
                                                {
                                                    <strong>CI Checks:</strong>
                                                    <ul class="mb-2">
                                                        @foreach (var check in pr.CheckRuns)
                                                        {
                                                            <li>
                                                                @CheckConclusionToEmoji(check.Conclusion, check.Status)
                                                                @if (check.Url != null)
                                                                {
                                                                    <a href="@check.Url" target="_blank">@check.Name</a>
                                                                }
                                                                else
                                                                {
                                                                    @check.Name
                                                                }
                                                                <small class="text-muted">(@(check.Conclusion ?? check.Status))</small>
                                                            </li>
                                                        }
                                                    </ul>
                                                }

                                                @if (pr.Comments is { Count: > 0 })
                                                {
                                                    <strong>Comments (non-bot):</strong>
                                                    <ul class="mb-2">
                                                        @foreach (var comment in pr.Comments)
                                                        {
                                                            <li>
                                                                <strong>@comment.Author</strong>
                                                                <small class="text-muted">@comment.CreatedAt.ToString("g")</small>:
                                                                @comment.Body
                                                            </li>
                                                        }
                                                    </ul>
                                                }

                                                @if (pr.Reviews is { Count: > 0 })
                                                {
                                                    <strong>Reviews:</strong>
                                                    <ul class="mb-0">
                                                        @foreach (var review in pr.Reviews)
                                                        {
                                                            <li>
                                                                <strong>@review.Author</strong>: @review.State
                                                                @if (review.SubmittedAt.HasValue)
                                                                {
                                                                    <small class="text-muted">@review.SubmittedAt.Value.ToString("g")</small>
                                                                }
                                                            </li>
                                                        }
                                                    </ul>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                }
            }
        </div>
    }

    @* === Subscriptions display === *@
    @if (filteredSubscriptions.Count > 0)
    {
        <h4>Subscriptions</h4>
        <table class="table table-hover w-auto align-middle">
            <thead>
                <tr>
                    <th>Source Repo</th>
                    <th>Source Branch</th>
                    <th>Channel</th>
                    <th>Target Repo</th>
                    <th>Target Branch</th>
                    <th>Frequency</th>
                    <th>Enabled</th>
                    <th>Batchable</th>
                    <th title="Merge Policies">Policies</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sub in filteredSubscriptions)
                {
                    <tr>
                        <td>@sub.SourceRepoShort</td>
                        <td><code>@(sub.TargetBranch ?? "—")</code></td>
                        <td><span class="badge bg-info text-dark">@(sub.Channel ?? "—")</span></td>
                        <td>@sub.TargetRepoShort</td>
                        <td><code>@(sub.TargetBranch ?? "—")</code></td>
                        <td>@(sub.UpdateFrequency ?? "—")</td>
                        <td>@(sub.Enabled ? "✔" : "✘")</td>
                        <td>@(sub.Batchable ? "✔" : "—")</td>
                        <td>@sub.MergePolicySummary</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@if (actionMessage != null)
{
    <div class="alert @(actionSuccess ? "alert-success" : "alert-warning") alert-dismissible mt-3">
        @actionMessage
        <button type="button" class="btn-close" @onclick="() => actionMessage = null"></button>
    </div>
}


@code {
    // === State ===
    private bool browser;
    private string? adoAccessToken;
    private string? gitHubToken;
    private string? gitHubUser;
    private HttpClient adoClient = new();
    private HttpClient gitHubClient = new();

    // Subscriptions state (preserved across navigations via FlowsState).
    private MaestroConfig? config { get => FlowsState.Config; set => FlowsState.Config = value; }
    private List<string> repos { get => FlowsState.Repos; set => FlowsState.Repos = value; }
    private string? currentRepo { get => FlowsState.CurrentRepo; set => FlowsState.CurrentRepo = value; }
    private bool loadingSubscriptions;
    private string? subscriptionError;

    // Flow PRs state (preserved across navigations via FlowsState).
    private List<FlowPr>? flowPrs { get => FlowsState.FlowPrs; set => FlowsState.FlowPrs = value; }
    private bool loadingPrs;
    private string? prError;
    private HashSet<int> expandedPrs => FlowsState.ExpandedPrs;

    // Action state.
    private FlowPr? actionInProgressPr;
    private string? actionType;
    private string? actionMessage;
    private bool actionSuccess;

    private List<ArcadeSubscription> filteredSubscriptions =>
        config?.Subscriptions
            .Where(s => string.Equals(s.SourceRepoShort, currentRepo, StringComparison.OrdinalIgnoreCase)
                     || string.Equals(s.TargetRepoShort, currentRepo, StringComparison.OrdinalIgnoreCase))
            .OrderBy(s => s.Channel)
            .ThenBy(s => s.SourceRepoShort)
            .ToList() ?? [];

    // === Lifecycle ===
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Read GitHub token from OAuth cookie.
            var httpContext = ContextAccessor.HttpContext;
            if (httpContext?.User?.Identity?.IsAuthenticated == true)
            {
                gitHubToken = await httpContext.GetTokenAsync("access_token");
                gitHubUser = httpContext.User.Identity.Name;
            }

            if (!string.IsNullOrEmpty(gitHubToken))
            {
                SetupGitHubClient();
            }

            browser = true;
            StateHasChanged();
        }
    }

    // === ADO Auth ===
    private async Task HandleAdoTokenChanged(string? token)
    {
        adoAccessToken = token;
        if (token != null)
        {
            subscriptionError = null;
            if (FlowsState.AdoAccessToken != token)
            {
                FlowsState.AdoAccessToken = token;
                config = null;
            }
            SetupAdoClient();
            if (config == null)
            {
                await LoadSubscriptionsAsync();
            }
        }
        else
        {
            FlowsState.AdoAccessToken = null;
            config = null;
            flowPrs = null;
        }
    }

    private void SetupAdoClient()
    {
        adoClient = new HttpClient(new LoggingHttpHandler(LoggerFactory.CreateLogger("HTTP.ADO")));
        adoClient.DefaultRequestHeaders.Add("Authorization", $"Bearer {adoAccessToken}");
    }

    private void SetupGitHubClient()
    {
        gitHubClient = new HttpClient(new LoggingHttpHandler(LoggerFactory.CreateLogger("HTTP.GitHub")));
        gitHubClient.DefaultRequestHeaders.Add("Authorization", $"Bearer {gitHubToken}");
        gitHubClient.DefaultRequestHeaders.Add("User-Agent", "VsInsertions");
        gitHubClient.DefaultRequestHeaders.Add("Accept", "application/vnd.github+json");
    }

    // === Load Subscriptions ===
    private async Task LoadSubscriptionsAsync()
    {
        loadingSubscriptions = true;
        subscriptionError = null;
        StateHasChanged();

        try
        {
            config = await MaestroConfigService.GetConfigAsync(adoClient);
            repos = MaestroConfigService.GetUniqueRepos(config.Subscriptions);
            if (repos.Count > 0 && (currentRepo == null || !repos.Contains(currentRepo)))
            {
                // Default to dotnet/roslyn if available, otherwise first repo.
                currentRepo = repos.FirstOrDefault(r => r.Equals("dotnet/roslyn", StringComparison.OrdinalIgnoreCase))
                    ?? repos[0];
            }
            flowPrs = null; // Reset PRs when subscriptions change.
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load subscriptions");
            subscriptionError = $"Failed to load subscriptions: {ex.Message}";
        }
        finally
        {
            loadingSubscriptions = false;
            StateHasChanged();
        }

        // Auto-load flow PRs if GitHub is signed in and a dotnet/ repo is selected.
        if (flowPrs == null && !string.IsNullOrEmpty(gitHubToken) && currentRepo?.StartsWith("dotnet/") == true)
        {
            await LoadFlowPrsAsync();
        }
    }

    // === Load Flow PRs ===
    private async Task LoadFlowPrsAsync()
    {
        if (string.IsNullOrEmpty(currentRepo))
            return;

        var parts = currentRepo.Split('/');
        if (parts.Length != 2)
            return;

        loadingPrs = true;
        prError = null;
        expandedPrs.Clear();
        StateHasChanged();

        try
        {
            flowPrs = await GitHubFlowService.GetFlowPrsAsync(gitHubClient, parts[0], parts[1]);
            // Load details for all PRs.
            foreach (var pr in flowPrs)
            {
                LoadPrDetailsInBackground(pr);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load flow PRs");
            prError = $"Failed to load flow PRs: {ex.Message}";
        }
        finally
        {
            loadingPrs = false;
            StateHasChanged();
        }
    }

    private async Task LoadPrDetailsAsync(FlowPr pr)
    {
        if (string.IsNullOrEmpty(currentRepo))
            return;

        var parts = currentRepo.Split('/');
        if (parts.Length != 2)
            return;

        await GitHubFlowService.LoadPrDetailsAsync(gitHubClient, parts[0], parts[1], pr);
        StateHasChanged();
    }

    private async void LoadPrDetailsInBackground(FlowPr pr)
    {
        try
        {
            await LoadPrDetailsAsync(pr);
        }
        catch (Exception ex)
        {
            // Swallow — details are optional.
            Logger.LogError(ex, "Failed to load PR details");
        }
    }

    // === Actions ===
    private async Task ApproveAndMergeAsync(FlowPr pr)
    {
        if (string.IsNullOrEmpty(currentRepo))
            return;

        var parts = currentRepo.Split('/');
        if (parts.Length != 2)
            return;

        actionInProgressPr = pr;
        actionType = "merge";
        actionMessage = null;
        StateHasChanged();

        try
        {
            var (success, message) = await GitHubFlowService.ApproveAndMergeAsync(gitHubClient, parts[0], parts[1], pr);
            actionSuccess = success;
            actionMessage = message;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to approve and merge PR");
            actionSuccess = false;
            actionMessage = $"Error: {ex.Message}";
        }
        finally
        {
            actionInProgressPr = null;
            actionType = null;
            StateHasChanged();
        }
    }

    private async Task RetryCiAsync(FlowPr pr)
    {
        if (string.IsNullOrEmpty(currentRepo))
            return;

        var parts = currentRepo.Split('/');
        if (parts.Length != 2)
            return;

        actionInProgressPr = pr;
        actionType = "retry";
        actionMessage = null;
        StateHasChanged();

        try
        {
            var (success, message) = await GitHubFlowService.RetryCiAsync(gitHubClient, parts[0], parts[1], pr);
            actionSuccess = success;
            actionMessage = message;

            // Refresh details after retry.
            if (success)
            {
                LoadPrDetailsInBackground(pr);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to retry CI");
            actionSuccess = false;
            actionMessage = $"Error: {ex.Message}";
        }
        finally
        {
            actionInProgressPr = null;
            actionType = null;
            StateHasChanged();
        }
    }

    // === UI Helpers ===
    private void ToggleDetails(FlowPr pr)
    {
        if (!expandedPrs.Remove(pr.Number))
            expandedPrs.Add(pr.Number);
    }

    private static string PrStateToEmoji(FlowPr pr) => pr switch
    {
        { Merged: true } => "🟣",
        { State: "open" } => "🟢",
        { State: "closed" } => "🔴",
        _ => "⚪",
    };

    private static string ReviewStateToColor(string state) => state switch
    {
        "APPROVED" => "green",
        "CHANGES_REQUESTED" => "red",
        "COMMENTED" => "orange",
        "DISMISSED" => "gray",
        _ => "lightgray",
    };

    private static string CheckConclusionToEmoji(string? conclusion, string status) => (conclusion, status) switch
    {
        ("success", _) => "✔",
        ("failure", _) => "✘",
        ("cancelled", _) => "⊘",
        ("timed_out", _) => "⏰",
        (null, "queued") => "⏳",
        (null, "in_progress") => "🔄",
        _ => "—",
    };

    private static string TruncateTitle(string title)
    {
        const int maxLength = 80;
        if (title.Length <= maxLength) return title;
        return title[..maxLength] + "…";
    }
}
