@page "/flows"
@using Microsoft.AspNetCore.Authentication
@using System.Text.Json.Nodes
@rendermode RenderMode.InteractiveServer
@inject IJSRuntime JSRuntime
@inject IConfiguration Configuration
@inject NavigationManager NavigationManager
@inject IHttpContextAccessor ContextAccessor
@inject MaestroConfigService MaestroConfigService
@inject GitHubFlowService GitHubFlowService
@inject ILogger<Flows> Logger
@inject ILoggerFactory LoggerFactory
@inject FlowsState FlowsState

<PageTitle>Flows</PageTitle>

<SectionContent SectionName="page-title">
    <h1 class="page-title">Arcade Flows</h1>
</SectionContent>

@* === Auth & Load controls === *@
<div class="my-2 d-flex flex-wrap align-items-center gap-2">
    <AdoLogin Organization="dnceng" CookieName="flows_ado_token"
              AccessToken="@adoAccessToken" AccessTokenChanged="HandleAdoTokenChanged"
              LoginLabel="Log In (ADO)" LogoutLabel="Log Out (ADO)" />

    @if (browser)
    {
        @if (string.IsNullOrEmpty(gitHubToken))
        {
            <a href="/signin-github-start?returnUrl=/flows" class="btn btn-dark">
                Sign in with GitHub
            </a>
            <small class="text-muted">Required for viewing and managing flow PRs</small>
        }
        else
        {
            <span class="badge bg-success">GitHub: @(gitHubUser ?? "signed in")</span>
            <a href="/signout-github" data-enhance-nav="false" class="btn btn-outline-dark btn-sm">Sign out (GitHub)</a>
        }
    }

    @if (!string.IsNullOrEmpty(adoAccessToken))
    {
        <button class="btn btn-primary" @onclick="LoadSubscriptionsAsync" disabled="@loadingSubscriptions">
            @(loadingSubscriptions ? "Loading..." : "Load Subscriptions")
        </button>

        @if (config != null && !string.IsNullOrEmpty(gitHubToken) && currentRepo?.StartsWith("dotnet/") == true)
        {
            <button class="btn btn-outline-secondary" @onclick="LoadAllFlowPrsAsync" disabled="@(loadingPrs || loadingOutgoingPrs)">
                @(loadingPrs || loadingOutgoingPrs ? "Loading PRs..." : "Load / Refresh PRs")
            </button>
        }
    }
</div>

@if (subscriptionError != null)
{
    <div class="alert alert-danger mt-2">@subscriptionError</div>
}

@* === Subscriptions display === *@
@if (config != null)
{
    <div class="my-3">
        <label class="me-1">Repository:</label>
        <select class="form-select d-inline-block w-auto me-3" @bind="currentRepo">
            @foreach (var repo in repos)
            {
                <option value="@repo">@repo</option>
            }
        </select>

        <span class="text-muted">@filteredSubscriptions.Count subscription(s)</span>
    </div>

    @* === Unified flows === *@
    <UnifiedFlowTable Rows="unifiedRows"
                      PrsAvailable="@(!string.IsNullOrEmpty(gitHubToken) && currentRepo?.StartsWith("dotnet/") == true)"
                      PrError="@prError"
                      OutgoingPrError="@outgoingPrError"
                      ExpandedPrs="expandedPrs"
                      ActionInProgressPr="actionInProgressPr"
                      ActionType="@actionType"
                      OnApproveAndMerge="ApproveAndMergeAsync"
                      OnRetryCi="RetryCiAsync" />
}

@if (actionMessage != null)
{
    <div class="alert @(actionSuccess ? "alert-success" : "alert-warning") alert-dismissible mt-3">
        @actionMessage
        <button type="button" class="btn-close" @onclick="() => actionMessage = null"></button>
    </div>
}


@code {
    // === State ===
    private bool browser;
    private string? adoAccessToken;
    private string? gitHubToken;
    private string? gitHubUser;
    private HttpClient adoClient = new();
    private HttpClient gitHubClient = new();

    // Subscriptions state (preserved across navigations via FlowsState).
    private MaestroConfig? config { get => FlowsState.Config; set => FlowsState.Config = value; }
    private List<string> repos { get => FlowsState.Repos; set => FlowsState.Repos = value; }
    private string? currentRepo { get => FlowsState.CurrentRepo; set => FlowsState.CurrentRepo = value; }
    private bool loadingSubscriptions;
    private string? subscriptionError;

    // Flow PRs state (preserved across navigations via FlowsState).
    private List<FlowPr>? flowPrs { get => FlowsState.FlowPrs; set => FlowsState.FlowPrs = value; }
    private List<FlowPr>? outgoingFlowPrs { get => FlowsState.OutgoingFlowPrs; set => FlowsState.OutgoingFlowPrs = value; }
    private List<FlowPr>? closedFlowPrs { get => FlowsState.ClosedFlowPrs; set => FlowsState.ClosedFlowPrs = value; }
    private List<FlowPr>? closedOutgoingFlowPrs { get => FlowsState.ClosedOutgoingFlowPrs; set => FlowsState.ClosedOutgoingFlowPrs = value; }
    private bool loadingPrs;
    private bool loadingOutgoingPrs;
    private string? prError;
    private string? outgoingPrError;
    private HashSet<int> expandedPrs => FlowsState.ExpandedPrs;

    // Action state.
    private FlowPr? actionInProgressPr;
    private string? actionType;
    private string? actionMessage;
    private bool actionSuccess;

    private List<ArcadeSubscription> filteredSubscriptions =>
        config?.Subscriptions
            .Where(s => string.Equals(s.SourceRepoShort, currentRepo, StringComparison.OrdinalIgnoreCase)
                     || string.Equals(s.TargetRepoShort, currentRepo, StringComparison.OrdinalIgnoreCase))
            .OrderBy(s => s.Channel)
            .ThenBy(s => s.SourceRepoShort)
            .ToList() ?? [];

    private List<ArcadeSubscription> incomingSubscriptions =>
        filteredSubscriptions
            .Where(s => string.Equals(s.TargetRepoShort, currentRepo, StringComparison.OrdinalIgnoreCase))
            .ToList();

    private List<ArcadeSubscription> outgoingSubscriptions =>
        filteredSubscriptions
            .Where(s => string.Equals(s.SourceRepoShort, currentRepo, StringComparison.OrdinalIgnoreCase))
            .ToList();

    // === Lifecycle ===
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Read GitHub token from OAuth cookie.
            var httpContext = ContextAccessor.HttpContext;
            if (httpContext?.User?.Identity?.IsAuthenticated == true)
            {
                gitHubToken = await httpContext.GetTokenAsync("access_token");
                gitHubUser = httpContext.User.Identity.Name;
            }

            if (!string.IsNullOrEmpty(gitHubToken))
            {
                SetupGitHubClient();
            }

            browser = true;
            StateHasChanged();
        }
    }

    // === ADO Auth ===
    private async Task HandleAdoTokenChanged(string? token)
    {
        adoAccessToken = token;
        if (token != null)
        {
            subscriptionError = null;
            if (FlowsState.AdoAccessToken != token)
            {
                FlowsState.AdoAccessToken = token;
                config = null;
            }
            SetupAdoClient();
            if (config == null)
            {
                await LoadSubscriptionsAsync();
            }
        }
        else
        {
            FlowsState.AdoAccessToken = null;
            config = null;
            flowPrs = null;
            outgoingFlowPrs = null;
            closedFlowPrs = null;
            closedOutgoingFlowPrs = null;
        }
    }

    private void SetupAdoClient()
    {
        adoClient = new HttpClient(new LoggingHttpHandler(LoggerFactory.CreateLogger("HTTP.ADO")));
        adoClient.DefaultRequestHeaders.Add("Authorization", $"Bearer {adoAccessToken}");
    }

    private void SetupGitHubClient()
    {
        gitHubClient = new HttpClient(new LoggingHttpHandler(LoggerFactory.CreateLogger("HTTP.GitHub")));
        gitHubClient.DefaultRequestHeaders.Add("Authorization", $"Bearer {gitHubToken}");
        gitHubClient.DefaultRequestHeaders.Add("User-Agent", "VsInsertions");
        gitHubClient.DefaultRequestHeaders.Add("Accept", "application/vnd.github+json");
    }

    // === Load Subscriptions ===
    private async Task LoadSubscriptionsAsync()
    {
        loadingSubscriptions = true;
        subscriptionError = null;
        StateHasChanged();

        try
        {
            config = await MaestroConfigService.GetConfigAsync(adoClient);
            repos = MaestroConfigService.GetUniqueRepos(config.Subscriptions);
            if (repos.Count > 0 && (currentRepo == null || !repos.Contains(currentRepo)))
            {
                // Default to dotnet/roslyn if available, otherwise first repo.
                currentRepo = repos.FirstOrDefault(r => r.Equals("dotnet/roslyn", StringComparison.OrdinalIgnoreCase))
                    ?? repos[0];
            }
            flowPrs = null; // Reset PRs when subscriptions change.
            outgoingFlowPrs = null;
            closedFlowPrs = null;
            closedOutgoingFlowPrs = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load subscriptions");
            subscriptionError = $"Failed to load subscriptions: {ex.Message}";
        }
        finally
        {
            loadingSubscriptions = false;
            StateHasChanged();
        }

        // Auto-load flow PRs if GitHub is signed in and a dotnet/ repo is selected.
        if (flowPrs == null && !string.IsNullOrEmpty(gitHubToken) && currentRepo?.StartsWith("dotnet/") == true)
        {
            await Task.WhenAll(LoadFlowPrsAsync(), LoadOutgoingFlowPrsAsync());
        }
    }

    // === Load Flow PRs ===
    private async Task LoadAllFlowPrsAsync()
    {
        await Task.WhenAll(LoadFlowPrsAsync(), LoadOutgoingFlowPrsAsync());
    }

    private async Task LoadFlowPrsAsync()
    {
        if (string.IsNullOrEmpty(currentRepo))
            return;

        var parts = currentRepo.Split('/');
        if (parts.Length != 2)
            return;

        loadingPrs = true;
        prError = null;
        expandedPrs.Clear();
        StateHasChanged();

        try
        {
            var openTask = GitHubFlowService.GetFlowPrsAsync(gitHubClient, parts[0], parts[1]);
            var closedTask = GitHubFlowService.GetFlowPrsAsync(gitHubClient, parts[0], parts[1], state: "closed", perPage: 10);
            await Task.WhenAll(openTask, closedTask);

            flowPrs = openTask.Result
                .OrderBy(p => p.Repo, StringComparer.OrdinalIgnoreCase)
                .ThenByDescending(p => p.Number)
                .ToList();
            closedFlowPrs = closedTask.Result
                .OrderBy(p => p.Repo, StringComparer.OrdinalIgnoreCase)
                .ThenByDescending(p => p.Number)
                .ToList();
            // Load details for all PRs.
            foreach (var pr in flowPrs)
            {
                LoadPrDetailsInBackground(pr);
            }
            foreach (var pr in closedFlowPrs)
            {
                LoadPrDetailsInBackground(pr);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load flow PRs");
            prError = $"Failed to load flow PRs: {ex.Message}";
        }
        finally
        {
            loadingPrs = false;
            StateHasChanged();
        }
    }

    // === Load Outgoing Flow PRs ===
    private async Task LoadOutgoingFlowPrsAsync()
    {
        if (string.IsNullOrEmpty(currentRepo) || config is null)
            return;

        var parts = currentRepo.Split('/');
        if (parts.Length != 2)
            return;

        var targetRepos = outgoingSubscriptions
            .Select(s => s.TargetRepoShort)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (targetRepos.Count == 0)
        {
            outgoingFlowPrs = [];
            return;
        }

        loadingOutgoingPrs = true;
        outgoingPrError = null;
        StateHasChanged();

        try
        {
            var openTask = GitHubFlowService.GetOutgoingFlowPrsAsync(
                gitHubClient, parts[0], parts[1], targetRepos);
            var closedTask = GitHubFlowService.GetOutgoingFlowPrsAsync(
                gitHubClient, parts[0], parts[1], targetRepos, state: "closed", perPage: 10);
            await Task.WhenAll(openTask, closedTask);

            outgoingFlowPrs = openTask.Result
                .OrderBy(p => p.Repo, StringComparer.OrdinalIgnoreCase)
                .ThenByDescending(p => p.Number)
                .ToList();
            closedOutgoingFlowPrs = closedTask.Result
                .OrderBy(p => p.Repo, StringComparer.OrdinalIgnoreCase)
                .ThenByDescending(p => p.Number)
                .ToList();
            foreach (var pr in outgoingFlowPrs)
            {
                LoadPrDetailsInBackground(pr);
            }
            foreach (var pr in closedOutgoingFlowPrs)
            {
                LoadPrDetailsInBackground(pr);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load outgoing flow PRs");
            outgoingPrError = $"Failed to load outgoing flow PRs: {ex.Message}";
        }
        finally
        {
            loadingOutgoingPrs = false;
            StateHasChanged();
        }
    }

    private async Task LoadPrDetailsAsync(FlowPr pr)
    {
        var parts = pr.Repo.Split('/');
        if (parts.Length != 2)
            return;

        await GitHubFlowService.LoadPrDetailsAsync(gitHubClient, parts[0], parts[1], pr);
        StateHasChanged();
    }

    private async void LoadPrDetailsInBackground(FlowPr pr)
    {
        try
        {
            await LoadPrDetailsAsync(pr);
        }
        catch (Exception ex)
        {
            // Swallow — details are optional.
            Logger.LogError(ex, "Failed to load PR details");
        }
    }

    // === Actions ===
    private async Task ApproveAndMergeAsync(FlowPr pr)
    {
        var parts = pr.Repo.Split('/');
        if (parts.Length != 2)
            return;

        actionInProgressPr = pr;
        actionType = "merge";
        actionMessage = null;
        StateHasChanged();

        try
        {
            var (success, message) = await GitHubFlowService.ApproveAndMergeAsync(gitHubClient, parts[0], parts[1], pr);
            actionSuccess = success;
            actionMessage = message;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to approve and merge PR");
            actionSuccess = false;
            actionMessage = $"Error: {ex.Message}";
        }
        finally
        {
            actionInProgressPr = null;
            actionType = null;
            StateHasChanged();
        }
    }

    private async Task RetryCiAsync(FlowPr pr)
    {
        var parts = pr.Repo.Split('/');
        if (parts.Length != 2)
            return;

        actionInProgressPr = pr;
        actionType = "retry";
        actionMessage = null;
        StateHasChanged();

        try
        {
            var (success, message) = await GitHubFlowService.RetryCiAsync(gitHubClient, parts[0], parts[1], pr);
            actionSuccess = success;
            actionMessage = message;

            // Refresh details after retry.
            if (success)
            {
                LoadPrDetailsInBackground(pr);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to retry CI");
            actionSuccess = false;
            actionMessage = $"Error: {ex.Message}";
        }
        finally
        {
            actionInProgressPr = null;
            actionType = null;
            StateHasChanged();
        }
    }

    // === UI Helpers ===

    /// <summary>
    /// Resolves the source branch for a subscription by looking up the default channel
    /// that matches the subscription's source repository and channel.
    /// </summary>
    private string? ResolveSourceBranch(ArcadeSubscription sub)
    {
        if (config is null || string.IsNullOrEmpty(sub.SourceRepository) || string.IsNullOrEmpty(sub.Channel))
            return null;

        var dc = FindDefaultChannel(sub.SourceRepoShort, sub.Channel)
              ?? FindDefaultChannel(sub.SourceRepoShort, sub.Channel + " - Validation");

        return dc?.Branch;
    }

    private DefaultChannel? FindDefaultChannel(string sourceRepoShort, string channel)
    {
        return config?.DefaultChannels.FirstOrDefault(dc =>
            dc.Enabled
            && string.Equals(dc.Channel, channel, StringComparison.OrdinalIgnoreCase)
            && string.Equals(
                MaestroConfigService.NormalizeRepoName(dc.Repository ?? ""),
                sourceRepoShort,
                StringComparison.OrdinalIgnoreCase));
    }

    // === Unified flow rows ===

    private List<UnifiedFlowRow> unifiedRows => BuildUnifiedFlowRows();

    private List<UnifiedFlowRow> BuildUnifiedFlowRows()
    {
        if (config is null)
            return [];

        var rows = new List<UnifiedFlowRow>();
        var matchedIncomingPrNumbers = new HashSet<int>();
        var matchedOutgoingPrNumbers = new HashSet<int>();

        // Incoming subscriptions (other → selected repo).
        foreach (var sub in incomingSubscriptions)
        {
            var matched = (flowPrs ?? [])
                .Where(pr => pr.Title.Contains(sub.SourceRepoShort, StringComparison.OrdinalIgnoreCase)
                    && MatchesTargetBranch(pr, sub.TargetBranch))
                .OrderByDescending(pr => pr.Number)
                .ToList();
            foreach (var pr in matched)
                matchedIncomingPrNumbers.Add(pr.Number);

            // If no open PRs, fall back to the most recent closed PR.
            if (matched.Count == 0)
            {
                var closedMatch = (closedFlowPrs ?? [])
                    .Where(pr => pr.Title.Contains(sub.SourceRepoShort, StringComparison.OrdinalIgnoreCase)
                        && MatchesTargetBranch(pr, sub.TargetBranch))
                    .OrderByDescending(pr => pr.Number)
                    .Take(1)
                    .ToList();
                matched = closedMatch;
            }

            rows.Add(new UnifiedFlowRow
            {
                OtherRepo = sub.SourceRepoShort,
                IsIncoming = true,
                Subscription = sub,
                SourceBranch = ResolveSourceBranch(sub),
                Prs = matched,
            });
        }

        // Outgoing subscriptions (selected repo → other).
        foreach (var sub in outgoingSubscriptions)
        {
            var matched = (outgoingFlowPrs ?? [])
                .Where(pr => string.Equals(pr.Repo, sub.TargetRepoShort, StringComparison.OrdinalIgnoreCase)
                    && MatchesTargetBranch(pr, sub.TargetBranch))
                .OrderByDescending(pr => pr.Number)
                .ToList();
            foreach (var pr in matched)
                matchedOutgoingPrNumbers.Add(pr.Number);

            // If no open PRs, fall back to the most recent closed PR.
            if (matched.Count == 0)
            {
                var closedMatch = (closedOutgoingFlowPrs ?? [])
                    .Where(pr => string.Equals(pr.Repo, sub.TargetRepoShort, StringComparison.OrdinalIgnoreCase)
                        && MatchesTargetBranch(pr, sub.TargetBranch))
                    .OrderByDescending(pr => pr.Number)
                    .Take(1)
                    .ToList();
                matched = closedMatch;
            }

            rows.Add(new UnifiedFlowRow
            {
                OtherRepo = sub.TargetRepoShort,
                IsIncoming = false,
                Subscription = sub,
                SourceBranch = ResolveSourceBranch(sub),
                Prs = matched,
            });
        }

        // Unmatched incoming PRs.
        if (flowPrs != null)
        {
            foreach (var pr in flowPrs.Where(p => !matchedIncomingPrNumbers.Contains(p.Number)))
            {
                rows.Add(new UnifiedFlowRow
                {
                    OtherRepo = ExtractSourceRepoFromTitle(pr.Title) ?? "unknown",
                    IsIncoming = true,
                    Prs = [pr],
                });
            }
        }

        // Unmatched outgoing PRs.
        if (outgoingFlowPrs != null)
        {
            foreach (var pr in outgoingFlowPrs.Where(p => !matchedOutgoingPrNumbers.Contains(p.Number)))
            {
                rows.Add(new UnifiedFlowRow
                {
                    OtherRepo = pr.Repo,
                    IsIncoming = false,
                    Prs = [pr],
                });
            }
        }

        return rows
            .OrderBy(r => r.OtherRepo, StringComparer.OrdinalIgnoreCase)
            .ThenBy(r => r.IsIncoming ? 0 : 1)
            .ThenBy(r => r.Subscription?.Channel)
            .ThenBy(r => r.Subscription?.TargetBranch)
            .ToList();
    }

    /// <summary>
    /// Extracts the source repo from a maestro PR title like
    /// "[main] Update dependencies from dotnet/runtime".
    /// </summary>
    private static string? ExtractSourceRepoFromTitle(string title)
    {
        var idx = title.IndexOf("from ", StringComparison.OrdinalIgnoreCase);
        if (idx >= 0)
        {
            var rest = title.AsSpan()[(idx + 5)..].Trim();
            var end = rest.IndexOf(' ');
            var token = end >= 0 ? rest[..end] : rest;
            if (token.IndexOf('/') >= 0)
                return token.ToString();
        }
        return null;
    }

    /// <summary>
    /// Checks if a PR matches the expected target branch.
    /// Uses <see cref="FlowPr.TargetBranch"/> if loaded, otherwise extracts
    /// the branch from the title (e.g., "[main] Update dependencies...").
    /// </summary>
    private static bool MatchesTargetBranch(FlowPr pr, string? expectedBranch)
    {
        if (expectedBranch is null)
            return true;

        var prBranch = pr.TargetBranch ?? ExtractTargetBranchFromTitle(pr.Title);
        if (prBranch is null)
            return true;

        return string.Equals(prBranch, expectedBranch, StringComparison.OrdinalIgnoreCase);
    }

    /// <summary>
    /// Extracts the target branch from a maestro PR title like
    /// "[main] Update dependencies from dotnet/runtime" → "main".
    /// </summary>
    private static string? ExtractTargetBranchFromTitle(string title)
    {
        if (title.StartsWith('['))
        {
            var end = title.IndexOf(']');
            if (end > 1)
                return title[1..end];
        }
        return null;
    }

}
