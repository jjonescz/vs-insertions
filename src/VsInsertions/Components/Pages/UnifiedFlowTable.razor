@* Unified flow table: subscriptions grouped by connected repo with matched PRs. *@

@if (PrError != null)
{
    <div class="alert alert-danger mt-2">@PrError</div>
}
@if (OutgoingPrError != null)
{
    <div class="alert alert-danger mt-2">@OutgoingPrError</div>
}

@if (Rows.Count == 0)
{
    <p class="text-muted">No subscriptions found.</p>
}
else
{
    var groups = Rows
        .GroupBy(r => r.OtherRepo, StringComparer.OrdinalIgnoreCase)
        .OrderBy(g => g.Key, StringComparer.OrdinalIgnoreCase)
        .ToList();
    var totalCols = PrsAvailable ? 11 : 4;

    <table class="table table-hover w-auto align-middle">
        <thead>
            <tr>
                <th></th>
                <th>Channel</th>
                <th>Source Branch</th>
                <th>Target Branch</th>
                @if (PrsAvailable)
                {
                    <th>PR</th>
                    <th>Date</th>
                    <th>CI</th>
                    <th title="Reviews">👀</th>
                    <th title="Non-bot comments">💬</th>
                    <th>Actions</th>
                    <th></th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var group in groups)
            {
                var inCount = group.Count(r => r.IsIncoming);
                var outCount = group.Count(r => !r.IsIncoming);
                var circularCount = group.Count(r => IsCircular(r));
                var prCount = group.Sum(r => r.Prs.Count);
                var disabledCount = group.Count(r => r.Subscription?.Enabled == false);
                var dirSymbol = circularCount == group.Count() ? "⇄" : (inCount > 0 && outCount > 0) ? "↔" : (inCount > 0 ? "←" : "→");
                var groupCollapseKey = CurrentRepo + "::" + group.Key;
                var isGroupCollapsed = CollapsedGroups.Contains(groupCollapseKey);

                <tr class="table-light" style="cursor: pointer;" @onclick="() => ToggleGroup(groupCollapseKey)" title="Click to collapse/expand group">
                    <td colspan="@totalCols">
                        <span class="me-1">@(isGroupCollapsed ? "▶" : "▼")</span>
                        <strong>@dirSymbol @group.Key</strong>
                        <small class="text-muted ms-2">
                            @{ var pureInCount = inCount - circularCount; }
                            @if (circularCount > 0) { <text>@circularCount circular</text> }
                            @if (circularCount > 0 && (pureInCount > 0 || outCount > 0)) { <text> · </text> }
                            @if (pureInCount > 0) { <text>@pureInCount incoming</text> }
                            @if (pureInCount > 0 && outCount > 0) { <text> · </text> }
                            @if (outCount > 0) { <text>@outCount outgoing</text> }
                            @if (PrsAvailable && prCount > 0) { <text> · @prCount PR(s)</text> }
                            @if (disabledCount > 0) { <text> · @disabledCount disabled</text> }
                        </small>
                    </td>
                </tr>

                @if (isGroupCollapsed) { continue; }

                @foreach (var row in group.OrderBy(r => r.Subscription?.Channel, StringComparer.OrdinalIgnoreCase))
                {
                    var primaryPr = row.Prs.FirstOrDefault();
                    var isExpanded = ExpandedRows.Contains(row.RowKey);
                    var isEnabled = row.Subscription?.Enabled ?? true;
                    var enabledSuffix = isEnabled ? "" : " (disabled)";
                    var stuck = IsStuck(row, out var overdueTime, out var stuckMessage);

                    <tr>
                        @* Direction *@
                        <td style="cursor: pointer;" @onclick="() => ToggleRow(row)" title="@((IsCircular(row) ? "Circular (self ↔ self)" : row.IsIncoming ? "Incoming (other → selected)" : "Outgoing (selected → other)") + enabledSuffix)">
                            @if (IsCircular(row))
                            {
                                <span class="badge @(isEnabled ? "bg-info text-dark" : "border border-info text-info")">⇄</span>
                            }
                            else if (row.IsIncoming)
                            {
                                <span class="badge @(isEnabled ? "bg-primary" : "border border-primary text-primary")">←</span>
                            }
                            else
                            {
                                <span class="badge @(isEnabled ? "bg-secondary" : "border border-secondary text-secondary")">→</span>
                            }
                            @if (stuck)
                            {
                                <span class="ms-1" title="@stuckMessage — @FormatOverdue(overdueTime) @(row.Subscription?.UpdateFrequency is { } freq ? $"(frequency: {freq})" : "")">⚠️</span>
                            }
                        </td>

                        @* Channel *@
                        <td style="cursor: pointer;" @onclick="() => ToggleRow(row)" title="@ChannelTooltip(primaryPr, row)">
                            @(row.Subscription?.Channel ?? "—")
                        </td>

                        @* Source Branch *@
                        <td style="cursor: pointer;" @onclick="() => ToggleRow(row)" title="Click to expand/collapse details"><code>@(row.SourceBranch ?? "—")</code></td>

                        @* Target Branch *@
                        <td style="cursor: pointer;" @onclick="() => ToggleRow(row)" title="Click to expand/collapse details"><code>@(row.Subscription?.TargetBranch ?? primaryPr?.TargetBranch ?? "—")</code></td>


                        @if (PrsAvailable)
                        {
                            @if (primaryPr != null)
                            {
                                @* PR link *@
                                <td>
                                    <span title="@PrStateTooltip(primaryPr)">@PrStateEmoji(primaryPr)</span>
                                    <a href="@primaryPr.Url" target="_blank" title="@primaryPr.Title">#@primaryPr.Number</a>
                                    @if (primaryPr.Mergeable == false)
                                    {
                                        <span class="ms-1" title="Merge conflicts">⛔</span>
                                    }
                                    @if (row.Prs.Count > 1)
                                    {
                                        <span class="badge bg-secondary ms-1" style="cursor: pointer;"
                                              title="Click to show all @row.Prs.Count PRs"
                                              @onclick="() => ToggleRow(row)">+@(row.Prs.Count - 1)</span>
                                    }
                                </td>

                                @* Date *@
                                <td style="cursor: pointer;" @onclick="() => ToggleRow(row)" title="@(primaryPr.UpdatedAt.HasValue ? $"Updated: {primaryPr.UpdatedAt.Value:g}" : "Click to expand/collapse details")">
                                    <small>@primaryPr.CreatedAt.ToString("d")</small>
                                </td>

                                @* CI *@
                                <td style="cursor: pointer;" @onclick="() => ToggleRow(row)" title="@CiTooltip(primaryPr)">
                                    @if (!primaryPr.DetailsLoaded)
                                    {
                                        <span title="Loading details…">⏳</span>
                                    }
                                    else
                                    {
                                        <span>@primaryPr.CiSummary</span>
                                    }
                                </td>

                                @* Reviews *@
                                <td style="cursor: pointer;" @onclick="() => ToggleRow(row)" title="Click to expand/collapse details">
                                    @if (primaryPr.Reviews is null && !primaryPr.DetailsLoaded)
                                    {
                                        <span title="Loading details…">⏳</span>
                                    }
                                    else if (primaryPr.Reviews != null)
                                    {
                                        @foreach (var review in primaryPr.Reviews.GroupBy(r => r.Author).Select(g => g.Last()))
                                        {
                                            @if (review.AvatarUrl != null)
                                            {
                                                <img src="@review.AvatarUrl" title="@review.Author: @review.State"
                                                     style="width: 1.2em; height: 1.2em; border-radius: 50%; border: 0.15em solid @ReviewStateToColor(review.State); margin-right: 2px;" />
                                            }
                                            else
                                            {
                                                <span title="@review.Author: @review.State" style="color: @ReviewStateToColor(review.State);">
                                                    @review.Author[..1]
                                                </span>
                                            }
                                        }
                                    }
                                </td>

                                @* Comments *@
                                <td style="cursor: pointer;" @onclick="() => ToggleRow(row)" title="Click to expand/collapse details">
                                    @if (!primaryPr.DetailsLoaded)
                                    {
                                        <span title="Loading details…">⏳</span>
                                    }
                                    else
                                    {
                                        @(primaryPr.Comments?.Count ?? 0)
                                    }
                                </td>

                                @* Actions *@
                                <td>
                                    @if (primaryPr.State == "open" && !primaryPr.Merged)
                                    {
                                        <button class="btn @(primaryPr.NeedsApproval ? "btn-success" : "btn-outline-success") btn-sm me-1"
                                                @onclick="() => OnApprove.InvokeAsync(primaryPr)"
                                                disabled="@(primaryPr == ActionInProgressPr)"
                                                title="@(primaryPr.NeedsApproval ? "Approve this PR" : "Already approved — approve again")">
                                            @if (primaryPr == ActionInProgressPr && ActionType == "approve")
                                            {
                                                @:Approving...
                                            }
                                            else
                                            {
                                                @:Approve
                                            }
                                        </button>

                                        <button class="btn btn-primary btn-sm me-1"
                                                @onclick="() => OnMerge.InvokeAsync(primaryPr)"
                                                disabled="@(primaryPr == ActionInProgressPr || primaryPr.Mergeable == false)"
                                                title="@(primaryPr.Mergeable == false ? "PR is not mergeable (conflicts or requirements not met)" : "Squash-merge and delete branch")">
                                            @if (primaryPr == ActionInProgressPr && ActionType == "merge")
                                            {
                                                @:Merging...
                                            }
                                            else
                                            {
                                                @:Merge
                                            }
                                        </button>

                                        @if (primaryPr.DetailsLoaded && primaryPr.CheckRuns?.Any(c => c.Conclusion is "failure" or "cancelled" or "timed_out") == true)
                                        {
                                            <button class="btn btn-warning btn-sm"
                                                    @onclick="() => OnRetryCi.InvokeAsync(primaryPr)"
                                                    disabled="@(primaryPr == ActionInProgressPr)"
                                                    title="Re-run failed CI checks">
                                                @if (primaryPr == ActionInProgressPr && ActionType == "retry")
                                                {
                                                    @:Retrying...
                                                }
                                                else
                                                {
                                                    @:Retry CI
                                                }
                                            </button>
                                        }
                                    }
                                </td>

                                @* Expand toggle *@
                                <td>
                                    <button class="btn btn-outline-secondary btn-sm"
                                            @onclick="() => ToggleRow(row)"
                                            title="Click to expand/collapse details">
                                        @(isExpanded ? "▲" : "▼")
                                    </button>
                                </td>
                            }
                            else
                            {
                                @* No PRs matched *@
                                <td class="text-muted">—</td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td>
                                    <button class="btn btn-outline-secondary btn-sm"
                                            @onclick="() => ToggleRow(row)"
                                            title="Click to expand/collapse details">
                                        @(isExpanded ? "▲" : "▼")
                                    </button>
                                </td>
                            }
                        }
                    </tr>

                    @* Expanded details *@
                    @if (isExpanded)
                    {
                        <tr>
                            <td colspan="@totalCols">
                                <div class="p-2" style="background-color: #f8f9fa;">
                                    <div class="d-flex justify-content-end mb-1">
                                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => OnRefreshRow.InvokeAsync(row)" title="Refresh PR details">
                                            ↻ Refresh
                                        </button>
                                    </div>
                                    @if (row.Subscription?.Id != null)
                                    {
                                        <strong>Subscription ID:</strong>@(" ")<a href="https://maestro.dot.net/subscriptions?search=@row.Subscription.Id&showDisabled=True" target="_blank">@row.Subscription.Id</a><br/>
                                    }
                                    @foreach (var pr in row.Prs)
                                    {
                                        @if (row.Prs.Count > 1)
                                        {
                                            <div class="d-flex align-items-center gap-2 mb-1">
                                                <h6 class="mb-0">
                                                    <a href="@pr.Url" target="_blank">#@pr.Number</a>
                                                    @if (pr.Mergeable == false)
                                                    {
                                                        <span class="ms-1" title="Merge conflicts">⛔</span>
                                                    }
                                                </h6>
                                                @if (pr != primaryPr && pr.State == "open" && !pr.Merged)
                                                {
                                                    <button class="btn @(pr.NeedsApproval ? "btn-success" : "btn-outline-success") btn-sm"
                                                            @onclick="() => OnApprove.InvokeAsync(pr)"
                                                            disabled="@(pr == ActionInProgressPr)"
                                                            title="@(pr.NeedsApproval ? "Approve this PR" : "Already approved — approve again")">
                                                        @(pr == ActionInProgressPr && ActionType == "approve" ? "Approving..." : "Approve")
                                                    </button>
                                                    <button class="btn btn-primary btn-sm"
                                                            @onclick="() => OnMerge.InvokeAsync(pr)"
                                                            disabled="@(pr == ActionInProgressPr || pr.Mergeable == false)"
                                                            title="@(pr.Mergeable == false ? "PR is not mergeable" : "Squash-merge and delete branch")">
                                                        @(pr == ActionInProgressPr && ActionType == "merge" ? "Merging..." : "Merge")
                                                    </button>
                                                    @if (pr.DetailsLoaded && pr.CheckRuns?.Any(c => c.Conclusion is "failure" or "cancelled" or "timed_out") == true)
                                                    {
                                                        <button class="btn btn-warning btn-sm"
                                                                @onclick="() => OnRetryCi.InvokeAsync(pr)"
                                                                disabled="@(pr == ActionInProgressPr)"
                                                                title="Re-run failed CI checks">
                                                            @(pr == ActionInProgressPr && ActionType == "retry" ? "Retrying..." : "Retry CI")
                                                        </button>
                                                    }
                                                }
                                            </div>
                                        }

                                        <strong>Title:</strong>@(" ")@pr.Title<br/>
                                        <strong>Created:</strong> <span>@pr.CreatedAt.ToString("g")</span>
                                        @if (pr.UpdatedAt.HasValue)
                                        {
                                            <text> · <strong>Updated:</strong> <span>@pr.UpdatedAt.Value.ToString("g")</span></text>
                                        }
                                        <br/>

                                        @if (pr.CheckRuns is { Count: > 0 })
                                        {
                                            var nonSuccess = pr.CheckRuns.Where(c => c.Conclusion != "success").ToList();
                                            var successCount = pr.CheckRuns.Count - nonSuccess.Count;
                                            <strong>CI Checks:</strong>
                                            @if (nonSuccess.Count > 0)
                                            {
                                                <ul class="mb-2">
                                                    @foreach (var check in nonSuccess)
                                                    {
                                                        <li>
                                                            @CheckConclusionToEmoji(check.Conclusion, check.Status)
                                                            @if (check.Url != null)
                                                            {
                                                                <a href="@check.Url" target="_blank">@check.Name</a>
                                                            }
                                                            else
                                                            {
                                                                @check.Name
                                                            }
                                                            @(" ")
                                                            <small class="text-muted">(@(check.Conclusion ?? check.Status)@(check.Duration is { } dur ? $", {FormatDuration(dur)}" : ""))</small>
                                                            @if (!string.IsNullOrEmpty(check.Title))
                                                            {
                                                                <small class="text-muted"> — @check.Title</small>
                                                            }
                                                            @if (check.Annotations is { Count: > 0 })
                                                            {
                                                                <ul class="mb-1 ms-3" style="list-style: none; padding-left: 0;">
                                                                    @foreach (var ann in check.Annotations)
                                                                    {
                                                                        <li>
                                                                            <small class="@(ann.Level == "failure" ? "text-danger" : "text-warning")">
                                                                                <code>@ann.Path@(ann.Line.HasValue ? $"#L{ann.Line}" : "")</code>:
                                                                                @ann.Message
                                                                            </small>
                                                                        </li>
                                                                    }
                                                                </ul>
                                                            }
                                                        </li>
                                                    }
                                                </ul>
                                            }
                                            @if (successCount > 0)
                                            {
                                                <div class="text-muted mb-2">✔ @successCount check(s) passed</div>
                                            }
                                        }

                                        @if (pr.Comments is { Count: > 0 })
                                        {
                                            <strong>Comments (non-bot):</strong>
                                            <ul class="mb-2">
                                                @foreach (var comment in pr.Comments)
                                                {
                                                    <li>
                                                        <strong>@comment.Author</strong>
                                                        <small class="text-muted">@comment.CreatedAt.ToString("g")</small>:
                                                        @comment.Body
                                                    </li>
                                                }
                                            </ul>
                                        }

                                        @if (pr.Reviews is { Count: > 0 })
                                        {
                                            <strong>Reviews:</strong>
                                            <ul class="mb-0">
                                                @foreach (var review in pr.Reviews)
                                                {
                                                    <li>
                                                        <strong>@review.Author</strong>: @review.State
                                                        @if (review.SubmittedAt.HasValue)
                                                        {
                                                            @(" ")
                                                            <small class="text-muted">@review.SubmittedAt.Value.ToString("g")</small>
                                                        }
                                                    </li>
                                                }
                                            </ul>
                                        }

                                        @if (row.Prs.Count > 1 && pr != row.Prs[^1])
                                        {
                                            <hr/>
                                        }
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            }
        </tbody>
    </table>
}

@code {
    [Parameter] public List<UnifiedFlowRow> Rows { get; set; } = [];
    [Parameter] public bool PrsAvailable { get; set; }
    [Parameter] public string? PrError { get; set; }
    [Parameter] public string? OutgoingPrError { get; set; }
    [Parameter] public HashSet<string> ExpandedRows { get; set; } = [];
    [Parameter] public HashSet<string> CollapsedGroups { get; set; } = [];
    [Parameter] public string? CurrentRepo { get; set; }
    [Parameter] public FlowPr? ActionInProgressPr { get; set; }
    [Parameter] public string? ActionType { get; set; }
    [Parameter] public EventCallback<FlowPr> OnApprove { get; set; }
    [Parameter] public EventCallback<FlowPr> OnMerge { get; set; }
    [Parameter] public EventCallback<FlowPr> OnRetryCi { get; set; }
    [Parameter] public EventCallback<UnifiedFlowRow> OnRowExpanded { get; set; }
    [Parameter] public EventCallback<UnifiedFlowRow> OnRefreshRow { get; set; }
    [Parameter] public EventCallback OnCollapsedGroupsChanged { get; set; }

    private async Task ToggleGroup(string groupKey)
    {
        if (!CollapsedGroups.Remove(groupKey))
            CollapsedGroups.Add(groupKey);
        await OnCollapsedGroupsChanged.InvokeAsync();
    }

    private async Task ToggleRow(UnifiedFlowRow row)
    {
        if (!ExpandedRows.Remove(row.RowKey))
        {
            ExpandedRows.Add(row.RowKey);
            await OnRowExpanded.InvokeAsync(row);
        }
    }

    private static string ChannelTooltip(FlowPr? pr, UnifiedFlowRow row)
    {
        var parts = new List<string>();
        if (pr != null) parts.Add("Click to expand/collapse details");
        if (row.Subscription?.UpdateFrequency != null) parts.Add($"Frequency: {row.Subscription.UpdateFrequency}");
        return string.Join("\n", parts);
    }

    private static string PrStateEmoji(FlowPr pr) => pr switch
    {
        { Merged: true } => "🟣",
        { State: "closed" } => "🔴",
        _ => "🟢",
    };

    private static string PrStateTooltip(FlowPr pr) => pr switch
    {
        { Merged: true } => "Merged",
        { State: "closed" } => "Closed",
        _ => "Open",
    };

    private static string ReviewStateToColor(string state) => state switch
    {
        "APPROVED" => "green",
        "CHANGES_REQUESTED" => "red",
        "COMMENTED" => "orange",
        "DISMISSED" => "gray",
        _ => "lightgray",
    };

    private static bool IsCircular(UnifiedFlowRow row) =>
        row.IsSameRepo ||
        (row.Subscription != null &&
        string.Equals(row.Subscription.SourceRepoShort, row.Subscription.TargetRepoShort, StringComparison.OrdinalIgnoreCase));

    /// <summary>Returns the threshold after which a subscription with the given frequency is considered stuck.</summary>
    private static TimeSpan? GetFrequencyThreshold(string? frequency) => frequency?.ToLowerInvariant() switch
    {
        "everybuild" => TimeSpan.FromDays(2),
        "everyday" or "twicedaily" => TimeSpan.FromDays(3),
        "everyweek" => TimeSpan.FromDays(10),
        "everytwoweeks" => TimeSpan.FromDays(21),
        "everymonth" => TimeSpan.FromDays(45),
        _ => null,
    };

    private static readonly TimeSpan DefaultOpenPrThreshold = TimeSpan.FromDays(7);

    /// <summary>Checks if a subscription row might be stuck (no open PR and last PR is older than expected, or open PR lingering too long).</summary>
    private static bool IsStuck(UnifiedFlowRow row, out TimeSpan overdue, out string stuckMessage)
    {
        overdue = default;
        stuckMessage = "";

        var hasSubscription = row.Subscription is { Enabled: true };
        var threshold = hasSubscription ? GetFrequencyThreshold(row.Subscription!.UpdateFrequency) : null;

        // Check if there's an open PR that's been open for too long.
        var openPr = row.Prs.Where(p => p.State == "open").OrderBy(p => p.CreatedAt).FirstOrDefault();
        if (openPr != null)
        {
            var openThreshold = threshold ?? DefaultOpenPrThreshold;
            var elapsed = DateTimeOffset.UtcNow - openPr.CreatedAt;
            if (elapsed > openThreshold)
            {
                overdue = elapsed - openThreshold;
                stuckMessage = "PR open for a long time";
                return true;
            }
            return false;
        }

        // The remaining check (no open PR) only applies to rows with a subscription.
        if (!hasSubscription || threshold is null) return false;

        // Use the most recent closed/merged PR's UpdatedAt as the reference point.
        var lastPr = row.Prs.OrderByDescending(p => p.UpdatedAt ?? p.CreatedAt).FirstOrDefault();
        var lastDate = lastPr?.UpdatedAt ?? lastPr?.CreatedAt;
        if (lastDate is null) return false;

        var elapsed2 = DateTimeOffset.UtcNow - lastDate.Value;
        if (elapsed2 > threshold.Value)
        {
            overdue = elapsed2 - threshold.Value;
            stuckMessage = "Possibly stuck";
            return true;
        }
        return false;
    }

    private static string FormatOverdue(TimeSpan overdue)
    {
        if (overdue.TotalDays >= 1) return $"{(int)overdue.TotalDays}d overdue";
        if (overdue.TotalHours >= 1) return $"{(int)overdue.TotalHours}h overdue";
        return "overdue";
    }

    private static string CheckConclusionToEmoji(string? conclusion, string status) => (conclusion, status) switch
    {
        ("success", _) => "✔",
        ("failure", _) => "✘",
        ("cancelled", _) => "⊘",
        ("timed_out", _) => "⏰",
        (null, "queued") => "⏳",
        (null, "in_progress") => "🔄",
        _ => "—",
    };

    private static string CiTooltip(FlowPr pr)
    {
        if (pr.CheckRuns is not { Count: > 0 })
            return "Click to expand/collapse details";

        var failed = pr.CheckRuns
            .Where(c => c.Conclusion is "failure" or "cancelled" or "timed_out")
            .ToList();
        if (failed.Count == 0)
            return "Click to expand/collapse details";

        return string.Join("\n", failed.Select(c =>
        {
            var line = $"✘ {c.Name}";
            if (c.Duration is { } dur)
                line += $" ({FormatDuration(dur)})";
            if (!string.IsNullOrEmpty(c.Title))
                line += $" — {c.Title}";
            return line;
        }));
    }

    private static string FormatDuration(TimeSpan duration)
    {
        if (duration.TotalHours >= 1)
            return $"{(int)duration.TotalHours}h {duration.Minutes}m";
        if (duration.TotalMinutes >= 1)
            return $"{(int)duration.TotalMinutes}m {duration.Seconds}s";
        return $"{(int)duration.TotalSeconds}s";
    }
}
