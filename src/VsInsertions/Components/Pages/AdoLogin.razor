@using Microsoft.AspNetCore.DataProtection
@inject IJSRuntime JSRuntime
@inject IDataProtectionProvider DataProtectionProvider

@if (!browserReady)
{
    <em>Checking access token...</em>
}
else if (UseMultipleTokens)
{
    var tokens = CurrentAccessTokens;
    <div class="d-flex flex-wrap align-items-center gap-2">
        @if (tokens.Count > 0)
        {
            <span class="badge bg-primary">ADO PATs: @string.Join(", ", tokens.Keys.OrderBy(k => k, StringComparer.OrdinalIgnoreCase))</span>
            <button type="submit" class="btn btn-outline-primary btn-sm" @onclick="LogOutAsync">@LogoutLabel</button>
        }
        <select class="form-select form-select-sm" style="width: 160px;" @bind="organizationInput">
            @foreach (var organization in OrganizationChoices)
            {
                <option value="@organization">@organization</option>
            }
        </select>
        <input type="password" class="form-control form-control-sm" style="width: 260px;"
               placeholder="Azure DevOps PAT" @bind="accessTokenInput" @bind:event="oninput" />
        <button type="submit" class="btn btn-primary btn-sm" @onclick="LogInAsync"
                disabled="@(string.IsNullOrWhiteSpace(organizationInput) || string.IsNullOrWhiteSpace(accessTokenInput))">Add PAT</button>
    </div>

    @if (!tokens.ContainsKey(NormalizeOrganization(Organization)))
    {
        <div class="text-warning small mt-1">A <code>@Organization</code> PAT is required to load subscriptions.</div>
    }

    @if (tokens.Count == 0 || !tokens.ContainsKey(NormalizeOrganization(Organization)))
    {
        @PatInstructions
    }
}
else if (string.IsNullOrEmpty(AccessToken))
{
    <div class="row g-3 align-items-center">
        <div class="col-auto">
            <input type="password" class="form-control" placeholder="Azure DevOps PAT (@Organization scope)" @bind="accessTokenInput" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary" @onclick="LogInAsync">@LoginLabel</button>
        </div>
    </div>

    @PatInstructions
}
else
{
    <button type="submit" class="btn btn-outline-primary me-2" @onclick="LogOutAsync">@LogoutLabel</button>
}

@code {
    private RenderFragment PatInstructions => @<details class="my-2">
        <summary>How do I get the PAT?</summary>
        <p>
            Use the
            <a href="https://dev.azure.com/dnceng/public/_artifacts/feed/dotnet-eng/NuGet/Microsoft.DncEng.PatGeneratorTool" target="_blank" rel="noopener noreferrer">PatGeneratorTool</a>:
        </p>
        <ol>
            <li>
                <CopyableCode Code="dotnet tool install --global Microsoft.DncEng.PatGeneratorTool --add-source https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-eng/nuget/v3/index.json --prerelease" />
            </li>
            <li>
                <CopyableCode Code="@($"pat-generator --scopes code_write build_execute --organizations {Organization} --expires-in 7")" />
            </li>
        </ol>
        @if (UseMultipleTokens)
        {
            <p>
                Run the command once for each Azure DevOps organization you need, then add each PAT separately.
            </p>
        }
        <p>
            Alternatively, go to <a href="@($"https://dev.azure.com/{Organization}/_usersSettings/tokens")" target="_blank" rel="noopener noreferrer">Azure DevOps &gt; PATs</a>
            and create a token with <code>Code (Read &amp; write)</code> and <code>Build (Read &amp; execute)</code> permissions for the <code>@Organization</code> organization.
        </p>
    </details>;

    [Parameter, EditorRequired] public string Organization { get; set; } = "";
    [Parameter, EditorRequired] public string CookieName { get; set; } = "";
    [Parameter] public string? AccessToken { get; set; }
    [Parameter] public EventCallback<string?> AccessTokenChanged { get; set; }
    [Parameter] public Dictionary<string, string>? AccessTokens { get; set; }
    [Parameter] public EventCallback<Dictionary<string, string>> AccessTokensChanged { get; set; }
    [Parameter] public IReadOnlyList<string>? OrganizationOptions { get; set; }
    [Parameter] public string LoginLabel { get; set; } = "Log In";
    [Parameter] public string LogoutLabel { get; set; } = "Log Out";

    private string? accessTokenInput;
    private string? organizationInput;
    private bool browserReady;

    private bool UseMultipleTokens => AccessTokensChanged.HasDelegate;

    private Dictionary<string, string> CurrentAccessTokens => AccessTokens is null
        ? new(StringComparer.OrdinalIgnoreCase)
        : new(AccessTokens, StringComparer.OrdinalIgnoreCase);

    private List<string> OrganizationChoices =>
        (OrganizationOptions is { Count: > 0 } ? OrganizationOptions : [Organization])
            .Append(Organization)
            .Where(o => !string.IsNullOrWhiteSpace(o))
            .Select(NormalizeOrganization)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(o => string.Equals(o, Organization, StringComparison.OrdinalIgnoreCase) ? 0 : 1)
            .ThenBy(o => o, StringComparer.OrdinalIgnoreCase)
            .ToList();

    protected override void OnParametersSet()
    {
        if (string.IsNullOrWhiteSpace(organizationInput) || !OrganizationChoices.Contains(organizationInput, StringComparer.OrdinalIgnoreCase))
        {
            organizationInput = Organization;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var encrypted = await JSRuntime.InvokeAsync<string>("getCookie", CookieName);
            try
            {
                var value = string.IsNullOrEmpty(encrypted) ? null :
                    DataProtectionProvider.CreateProtector(CookieName).Unprotect(encrypted);
                if (UseMultipleTokens)
                {
                    await AccessTokensChanged.InvokeAsync(DeserializeAccessTokens(value));
                }
                else
                {
                    await AccessTokenChanged.InvokeAsync(value);
                }
            }
            catch
            {
                if (UseMultipleTokens)
                {
                    await AccessTokensChanged.InvokeAsync(new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase));
                }
                else
                {
                    await AccessTokenChanged.InvokeAsync(null);
                }
            }

            browserReady = true;
            StateHasChanged();
        }
    }

    private async Task LogInAsync()
    {
        if (string.IsNullOrEmpty(accessTokenInput))
            return;

        if (UseMultipleTokens)
        {
            if (string.IsNullOrWhiteSpace(organizationInput))
                return;

            var tokens = CurrentAccessTokens;
            tokens[NormalizeOrganization(organizationInput)] = accessTokenInput.Trim();
            await SaveAccessTokensAsync(tokens);
            await AccessTokensChanged.InvokeAsync(tokens);
        }
        else
        {
            var token = accessTokenInput;
            var encrypted = DataProtectionProvider.CreateProtector(CookieName).Protect(token);
            await JSRuntime.InvokeVoidAsync("setCookie", CookieName, encrypted);
            await AccessTokenChanged.InvokeAsync(token);
        }

        accessTokenInput = null;
    }

    private async Task LogOutAsync()
    {
        await JSRuntime.InvokeVoidAsync("setCookie", CookieName, "");
        if (UseMultipleTokens)
        {
            await AccessTokensChanged.InvokeAsync(new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase));
        }
        else
        {
            await AccessTokenChanged.InvokeAsync(null);
        }
    }

    private async Task SaveAccessTokensAsync(Dictionary<string, string> tokens)
    {
        var json = System.Text.Json.JsonSerializer.Serialize(tokens);
        var encrypted = DataProtectionProvider.CreateProtector(CookieName).Protect(json);
        await JSRuntime.InvokeVoidAsync("setCookie", CookieName, encrypted);
    }

    private Dictionary<string, string> DeserializeAccessTokens(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        if (value.TrimStart().StartsWith("{", StringComparison.Ordinal))
        {
            var tokens = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(value)
                ?? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            return new Dictionary<string, string>(
                tokens.Where(kvp => !string.IsNullOrWhiteSpace(kvp.Key) && !string.IsNullOrWhiteSpace(kvp.Value))
                    .ToDictionary(kvp => NormalizeOrganization(kvp.Key), kvp => kvp.Value, StringComparer.OrdinalIgnoreCase),
                StringComparer.OrdinalIgnoreCase);
        }

        return new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            [NormalizeOrganization(Organization)] = value,
        };
    }

    private static string NormalizeOrganization(string organization) => organization.Trim();
}
